</BaseLayout>

<style>
  .legal-prose h2 {
    color: #0a0a0a;
    font-family: "Satoshi", system-ui, sans-serif;
    font-weight: 300;
  }
  .legal-prose a {
    color: #987622;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .legal-prose a:hover {
    color: #bc922c;
  }
</style>
