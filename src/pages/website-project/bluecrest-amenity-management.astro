---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

// -----------------------------------------------------------------------------
// Image assets expected at /public/images/projects/bluecrest/
// (Drop the files in and they will render automatically.)
//
//   thumbnail.webp        -used by /website-design grid card (1200x900)
//   home.webp             -home page screenshot
//   page-*.webp           -other pages we built (see `pages` array below)
// -----------------------------------------------------------------------------

const meta = [
  { k: 'Client', v: 'Daniel Barber' },
  { k: 'Industry', v: 'Aquatic Amenities' },
  {
    k: 'What we did',
    items: [
      'Website Development',
      'SEO Optimization',
      'Content Writing',
      'Graphic Design',
    ],
  },
];

const palette = [
  { name: 'Pool Blue',  hex: '#0256B9', use: 'Primary brand, links, action accents',           text: 'light' },
  { name: 'Deep Navy',  hex: '#072F6D', use: 'Headers, authority, trust signals',              text: 'light' },
  { name: 'Tide',       hex: '#5F84A2', use: 'Supporting surfaces, secondary text, dividers',  text: 'light' },
  { name: 'Foam',       hex: '#E8E9E4', use: 'Soft backgrounds, calm sections',                text: 'dark'  },
];

const pages = [
  { name: 'Home',     img: '/images/projects/bluecrest/home.webp' },
  { name: 'About',    img: '/images/projects/bluecrest/page-about.webp' },
  { name: 'Contact',  img: '/images/projects/bluecrest/page-contact.webp' },
];
---

<BaseLayout
  title="Bluecrest Amenity Management | Website Development · Rumeira"
  description="A conversion-driven website for a leading pool management and aquatic services firm, built around trust, clarity, and the rhythm of the swim season."
  canonical="https://rumeira.com/website-project/bluecrest-amenity-management"
>
  <Nav />
  <main id="main">

    <!-- ========== HERO ========== -->
    <section class="relative overflow-hidden bg-white pt-32 pb-16 md:pt-40 md:pb-20">
      <div class="pointer-events-none absolute inset-0 bg-grid-light opacity-60 [mask-image:radial-gradient(ellipse_at_top_left,black_20%,transparent_70%)]"></div>
      <div class="pointer-events-none absolute -top-32 left-[-10%] h-[560px] w-[560px] rounded-full bg-gold/15 blur-3xl"></div>

      <div class="container-x relative">
        <a href="/website-design" class="inline-flex items-center gap-2 text-sm text-ink/50 transition-colors hover:text-gold">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M11 6H1m0 0l5-5M1 6l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All projects
        </a>

        <div class="mt-8 grid items-end gap-10 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-8">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Website Project · Development
            </span>
            <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tightest text-ink sm:text-6xl md:text-7xl">
              Bluecrest Amenity Management
            </h1>
            <p class="mt-7 max-w-2xl text-balance text-lg leading-relaxed text-ink/65 md:text-xl">
              A high-converting website for a leading pool management and aquatic services firm, built around trust, clarity, and the rhythm of the swim season.
            </p>
          </div>

          <div class="lg:col-span-4 text-right">
            <a href="https://www.bluecrestam.com/" target="_blank" rel="noopener" class="btn-primary w-full sm:w-auto">
              Visit live site
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M5 9L9 5M9 5H5M9 5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="1.5" y="1.5" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="mt-14 grid grid-cols-2 gap-6 border-t border-black/10 pt-8 md:grid-cols-3">
          {meta.map((m) => (
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-ink/70">{m.k}</div>
              {m.items ? (
                <ul class="mt-2 flex flex-wrap gap-1.5">
                  {m.items.map((item) => (
                    <li class="rounded-full bg-ink/[0.06] px-2.5 py-1 text-xs font-medium text-ink/80">{item}</li>
                  ))}
                </ul>
              ) : (
                <div class="mt-2 text-sm font-medium text-ink">{m.v}</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== ABOUT THE CLIENT ========== -->
    <section class="bg-white py-20 md:py-28">
      <div class="container-x">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-5">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              About the client
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
              Full-service pool care, season after season.
            </h2>
          </div>
          <div class="space-y-6 text-base leading-relaxed text-ink/70 md:text-lg lg:col-span-7">
            <p>
              Bluecrest Amenity Management delivers comprehensive pool management solutions, covering routine maintenance, system repairs, and precise water balancing for residential and commercial properties.
            </p>
            <p>
              Alongside a seasoned team of technicians, Bluecrest staffs trained <span class="font-medium text-ink">lifeguards and aquatic personnel</span>, guaranteeing a safe and enjoyable experience for every patron, every visit.
            </p>
            <div class="grid grid-cols-3 gap-4 border-t border-black/10 pt-6">
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">365<span class="text-gold">d</span></div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Year-round care</div>
              </div>
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">Certified</div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Aquatic staff</div>
              </div>
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">Full<span class="text-gold">-service</span></div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Maintenance & lifeguards</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== BRAND PALETTE ========== -->
    <section class="bg-[#FBF8EF] py-20 md:py-28">
      <div class="container-x">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-2xl">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Brand palette
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
              Open water,<br/>
              <span class="text-gold">deep expertise.</span>
            </h2>
          </div>
          <p class="max-w-md text-base text-ink/60 md:text-lg">
            A palette that mirrors the surface and the depth of the work. Bright blue for action, deep navy for authority, tide and foam for the calm in between.
          </p>
        </div>

        <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {palette.map((c) => (
            <article class="overflow-hidden rounded-2xl border border-black/10 bg-white">
              <div
                class="h-32 w-full md:h-40"
                style={`background-color: ${c.hex};`}
              >
                <div class:list={["flex h-full items-end justify-between p-5", c.text === 'light' ? 'text-white' : 'text-ink']}>
                  <span class="font-display text-sm font-medium uppercase tracking-[0.18em]">{c.hex}</span>
                </div>
              </div>
              <div class="p-5">
                <div class="font-display text-base font-medium text-ink">{c.name}</div>
                <p class="mt-1.5 text-xs leading-relaxed text-ink/55">{c.use}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== PAGES WE BUILT ========== -->
    <section class="bg-white py-20 md:py-28">
      <div class="container-x">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-2xl">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Pages we shipped
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
              {pages.length} pages.<br/>
              <span class="text-gold">One coherent funnel.</span>
            </h2>
          </div>
          <p class="max-w-md text-base text-ink/60 md:text-lg">
            Each page has a single job. Hero qualifies, body builds trust, CTA collects the inquiry.
          </p>
        </div>

        <div class="mt-14 grid gap-8 sm:grid-cols-2">
          {pages.map((p) => (
            <figure class="overflow-hidden rounded-2xl border border-black/10 bg-white">
              <div class="relative h-[520px] overflow-y-auto bg-[#F3F4F6] md:h-[680px]">
                <img
                  src={p.img}
                  alt={`Bluecrest Amenity Management -${p.name} page`}
                  width="1200"
                  height="3000"
                  class="block w-full h-auto"
                  loading="lazy"
                />
                <div class="pointer-events-none sticky bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-white/90 to-transparent"></div>
              </div>
              <figcaption class="flex items-center justify-between p-5">
                <span class="font-display text-base font-medium">{p.name}</span>
                <span class="text-[10px] uppercase tracking-[0.18em] text-ink/40">Scroll to see full page</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== NEXT / BACK ========== -->
    <section class="bg-white py-16 md:py-20">
      <div class="container-x">
        <div class="flex flex-col items-start justify-between gap-6 border-t border-black/10 pt-10 sm:flex-row sm:items-center">
          <a href="/website-design" class="inline-flex items-center gap-2 text-sm font-medium text-ink/70 transition-colors hover:text-gold">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M11 6H1m0 0l5-5M1 6l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All website projects
          </a>
          <a href="https://www.bluecrestam.com/" target="_blank" rel="noopener" class="btn-secondary">
            Visit bluecrestam.com
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M4 8L8 4M8 4H4M8 4V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</BaseLayout>
