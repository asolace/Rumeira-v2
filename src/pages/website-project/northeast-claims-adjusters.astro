---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

// -----------------------------------------------------------------------------
// Image assets expected at /public/images/projects/nea/
// (Drop the files in and they will render automatically.)
//
//   thumbnail.webp   -used by /website-design grid card (1200x900)
//   home-old.webp    -old home page screenshot (full page or above-the-fold)
//   home-new.webp    -new home page screenshot
//   page-*.webp      -other pages we built (see `pages` array below)
// -----------------------------------------------------------------------------

const meta = [
  { k: 'Client', v: 'Joseph J Mainiero' },
  { k: 'Industry', v: 'Public Insurance Adjusting' },
  {
    k: 'What we did',
    items: [
      'Website Redesign',
      'Bilingual (EN + 中文)',
      'Video Production',
      'Graphic Design',
      'SEO Optimization',
      'Live Chat Bot',
      'Content Writing',
    ],
  },
];

const palette = [
  { name: 'Trust Navy', hex: '#0A2342', use: 'Primary brand -headers, navigation, authority',  text: 'light' },
  { name: 'Calm Sky',   hex: '#DFEBF6', use: 'Soft section backgrounds, supporting surfaces',  text: 'dark'  },
  { name: 'Clean White',hex: '#FFFFFF', use: 'Page backgrounds, text on navy',                 text: 'dark'  },
  { name: 'Action Red', hex: '#C8102E', use: 'CTAs, accents, urgency signals',                 text: 'light' },
];

// New pages we shipped -add/remove as needed.
const pages = [
  { name: 'Home',        img: '/images/projects/nea/home-new.webp' },
  { name: 'About',       img: '/images/projects/nea/page-about.webp' },
  { name: 'Policy',       img: '/images/projects/nea/page-policy.webp' },
  { name: 'Start Claim', img: '/images/projects/nea/page-start-claim.webp' },
  { name: 'Contact',     img: '/images/projects/nea/page-contact.webp' },
];

// Beyond-the-website work -full case study to be linked later.
const beyond = [
  { title: 'Video production',   body: 'Short-form ad creative and social cuts shot, edited, and delivered for paid + organic distribution.' },
  { title: 'Photography & imagery', body: 'Brand and service imagery designed for the new site and supporting campaigns.' },
  { title: 'Paid ads',           body: 'Campaign builds across the channels that move policyholder intent -search, social, and display.' },
  { title: 'Content production', body: 'Long-form articles and short posts that compound search and AI-search visibility over time.' },
];
---

<BaseLayout
  title="Northeast Claims Adjusters | Website Redesign · Rumeira"
  description="We built a high converting website for one of the largest insurance claims adjuster company in the northeast."
  canonical="https://rumeira.com/website-project/northeast-claims-adjusters"
>
  <Nav />
  <main id="main">

    <!-- ========== HERO ========== -->
    <section class="relative overflow-hidden bg-white pt-32 pb-16 md:pt-40 md:pb-20">
      <div class="pointer-events-none absolute inset-0 bg-grid-light opacity-60 [mask-image:radial-gradient(ellipse_at_top_left,black_20%,transparent_70%)]"></div>
      <div class="pointer-events-none absolute -top-32 left-[-10%] h-[560px] w-[560px] rounded-full bg-gold/15 blur-3xl"></div>

      <div class="container-x relative">
        <a href="/website-design" class="inline-flex items-center gap-2 text-sm text-ink/50 transition-colors hover:text-gold">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M11 6H1m0 0l5-5M1 6l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All projects
        </a>

        <div class="mt-8 grid items-end gap-10 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-8">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Website Project · Redesign
            </span>
            <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tightest text-ink sm:text-6xl md:text-7xl">
              Northeast Claims Adjusters
            </h1>
            <p class="mt-7 max-w-2xl text-balance text-lg leading-relaxed text-ink/65 md:text-xl">
              We built a high converting website for one of the largest insurance claims adjuster company in the northeast.
            </p>
          </div>

          <div class="lg:col-span-4 text-right">
            <a href="https://www.neadjustment.com/" target="_blank" rel="noopener" class="btn-primary w-full sm:w-auto">
              Visit live site
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M5 9L9 5M9 5H5M9 5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="1.5" y="1.5" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="mt-14 grid grid-cols-2 gap-6 border-t border-black/10 pt-8 md:grid-cols-3">
          {meta.map((m) => (
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-ink/70">{m.k}</div>
              {m.items ? (
                <ul class="mt-2 flex flex-wrap gap-1.5">
                  {m.items.map((item) => (
                    <li class="rounded-full bg-ink/[0.06] px-2.5 py-1 text-xs font-medium text-ink/80">{item}</li>
                  ))}
                </ul>
              ) : (
                <div class="mt-2 text-sm font-medium text-ink">{m.v}</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== ABOUT THE CLIENT ========== -->
    <section class="bg-white py-20 md:py-28">
      <div class="container-x">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-5">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              About the client
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
              Advocates for policyholders -never insurers.
            </h2>
          </div>
          <div class="space-y-6 text-base leading-relaxed text-ink/70 md:text-lg lg:col-span-7">
            <p>
              Northeast Claims Adjusters is one of the largest public insurance adjusting firms in the Northeast. Unlike adjusters who work for insurance carriers, NEA represents <span class="font-medium text-ink">policyholders</span> -homeowners and businesses fighting for fair settlements after property damage.
            </p>
            <p>
              With 50+ years of combined experience, the team manages a wide range of property damage claims and delivers clear, defensible documentation. Their mission is simple: protect the client, recover faster, and bring peace of mind back to the process.
            </p>
            <div class="grid grid-cols-3 gap-4 border-t border-black/10 pt-6">
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">50<span class="text-gold">+</span></div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Years experience</div>
              </div>
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">A<span class="text-gold">+</span></div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">BBB rating</div>
              </div>
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">4.8<span class="text-gold">/5</span></div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Google reviews</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== BRAND PALETTE ========== -->
    <section class="bg-[#FBF8EF] py-20 md:py-28">
      <div class="container-x">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-2xl">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Brand palette
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
              Trust, authority,<br/>
              <span class="text-gold">and clarity.</span>
            </h2>
          </div>
          <p class="max-w-md text-base text-ink/60 md:text-lg">
            A deliberately restrained system. Deep navy for authority, red for the action, sky and white for the calm that holds them together.
          </p>
        </div>

        <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {palette.map((c) => (
            <article class="overflow-hidden rounded-2xl border border-black/10 bg-white">
              <div
                class="h-32 w-full md:h-40"
                style={`background-color: ${c.hex};`}
              >
                <div class:list={["flex h-full items-end justify-between p-5", c.text === 'light' ? 'text-white' : 'text-ink']}>
                  <span class="font-display text-sm font-medium uppercase tracking-[0.18em]">{c.hex}</span>
                </div>
              </div>
              <div class="p-5">
                <div class="font-display text-base font-medium text-ink">{c.name}</div>
                <p class="mt-1.5 text-xs leading-relaxed text-ink/55">{c.use}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== BEFORE & AFTER ========== -->
    <section class="bg-white py-20 md:py-28">
      <div class="container-x">
        <div class="mx-auto max-w-3xl text-center">
          <span class="eyebrow">
            <span class="h-px w-6 bg-gold"></span>
            Before & After
          </span>
          <h2 class="mt-5 font-display text-3xl font-medium leading-[1.05] tracking-tight md:text-5xl">
            From dated brochure to working funnel.
          </h2>
          <p class="mx-auto mt-6 max-w-xl text-base text-ink/60 md:text-lg">
            The original site explained the service. The redesign asks for the lead -every section, every scroll.
          </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-2 md:gap-8">
          <figure class="flex flex-col">
            <figcaption class="mb-5 flex items-center gap-4">
              <span class="rounded-full bg-ink/[0.06] px-4 py-1.5 text-xs font-medium uppercase tracking-[0.18em] text-ink/55">Before</span>
              <span class="font-display text-lg font-medium text-ink/75 md:text-xl">Original home page</span>
            </figcaption>
            <div class="overflow-hidden rounded-2xl border border-black/10 bg-[#F3F4F6] shadow-[0_30px_80px_-30px_rgba(0,0,0,0.18)]">
              <img
                src="/images/projects/nea/home-old.webp"
                alt="Northeast Claims Adjusters -original home page"
                width="1200"
                height="900"
                class="w-full object-cover"
                loading="lazy"
              />
            </div>
          </figure>

          <figure class="flex flex-col">
            <figcaption class="mb-5 flex items-center gap-4">
              <span class="rounded-full bg-gold px-4 py-1.5 text-xs font-medium uppercase tracking-[0.18em] text-white">After</span>
              <span class="font-display text-lg font-medium text-ink/75 md:text-xl">Redesigned home page</span>
            </figcaption>
            <div class="overflow-hidden rounded-2xl border border-gold/30 bg-white shadow-[0_30px_80px_-30px_rgba(152,118,34,0.35)]">
              <img
                src="/images/projects/nea/home-new.webp"
                alt="Northeast Claims Adjusters -redesigned home page"
                width="1200"
                height="900"
                class="w-full object-cover"
                loading="lazy"
              />
            </div>
          </figure>
        </div>
      </div>
    </section>

    <!-- ========== PAGES WE BUILT ========== -->
    <section class="bg-[#FBF8EF] py-20 md:py-28">
      <div class="container-x">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-2xl">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Pages we shipped
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
              {pages.length} pages.<br/>
              <span class="text-gold">One coherent funnel.</span>
            </h2>
          </div>
          <p class="max-w-md text-base text-ink/60 md:text-lg">
            Each page has a single job. Hero qualifies, body builds trust, CTA collects the claim.
          </p>
        </div>

        <div class="mt-14 grid gap-8 sm:grid-cols-2">
          {pages.map((p) => (
            <figure class="overflow-hidden rounded-2xl border border-black/10 bg-white">
              <div class="relative h-[520px] overflow-y-auto bg-[#F3F4F6] md:h-[680px]">
                <img
                  src={p.img}
                  alt={`Northeast Claims Adjusters -${p.name} page`}
                  width="1200"
                  height="3000"
                  class="block w-full h-auto"
                  loading="lazy"
                />
                <div class="pointer-events-none sticky bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-white/90 to-transparent"></div>
              </div>
              <figcaption class="flex items-center justify-between p-5">
                <span class="font-display text-base font-medium">{p.name}</span>
                <span class="text-[10px] uppercase tracking-[0.18em] text-ink/90">Scroll to see full page</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== BILINGUAL ========== -->
    <section class="bg-white py-20 md:py-28">
      <div class="container-x">
        <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-6">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Localization
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.05] tracking-tight md:text-5xl">
              Built bilingual.<br/>
              English and <span class="text-gold">中文</span>.
            </h2>
            <p class="mt-6 text-base leading-relaxed text-ink/65 md:text-lg">
              NEA's client base includes a meaningful Chinese-speaking population. Every page on the new site ships in both English and Chinese -same conversion architecture, properly localized copy, language-aware metadata, and a clean toggle in the navigation.
            </p>
            <ul class="mt-8 space-y-3">
              {[
                'Full-site Chinese translation, not Google-Translate widget',
                'Language switcher persists across pages',
                'Hreflang tags for search & GEO',
                'Both languages share the same conversion structure',
              ].map((item) => (
                <li class="flex items-start gap-3 text-base text-ink/80">
                  <span class="mt-1 flex h-6 w-6 flex-none items-center justify-center rounded-full bg-gold/10">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                      <path d="M2 5.5L4 7.5L8 3" stroke="#987622" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="lg:col-span-6">
            <div class="rounded-2xl border border-black/10 bg-[#FBF8EF]/40 p-8 md:p-10">
              <div class="flex items-center justify-end gap-2">
                <button type="button" class="rounded-full bg-ink px-4 py-1.5 text-xs font-medium text-white">EN</button>
                <button type="button" class="rounded-full border border-black/10 px-4 py-1.5 text-xs font-medium text-ink/70">中文</button>
              </div>
              <div class="mt-8 grid gap-6 md:grid-cols-2">
                <div class="space-y-2">
                  <div class="text-[10px] uppercase tracking-[0.18em] text-ink/40">English</div>
                  <div class="font-display text-2xl font-medium leading-tight text-ink md:text-3xl">Less Stress. More Settlement.</div>
                  <p class="text-sm leading-relaxed text-ink/60">Don't settle for less, get your maximum claim settlement.</p>
                </div>
                <div class="space-y-2 border-t border-black/10 pt-6 md:border-l md:border-t-0 md:pl-6 md:pt-0">
                  <div class="text-[10px] uppercase tracking-[0.18em] text-ink/40">中文</div>
                  <div class="font-display text-2xl font-medium leading-tight text-ink md:text-3xl">减轻压力。 增加赔偿。</div>
                  <p class="text-sm leading-relaxed text-ink/60">不要满足于更少，争取您的最大理赔金额。</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== BEYOND THE WEBSITE ========== -->
    <section class="bg-black py-20 text-white md:py-28">
      <div class="pointer-events-none absolute inset-x-0 h-full bg-grid-dark opacity-20 [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"></div>
      <div class="container-x relative">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
          <div class="max-w-2xl">
            <span class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.2em] text-gold-soft">
              <span class="h-px w-6 bg-gold-soft"></span>
              Beyond the redesign
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.05] tracking-tight md:text-5xl">
              The website was the start, not the deliverable.
            </h2>
          </div>
          <p class="max-w-md text-base text-white/60 md:text-lg">
            Alongside the rebuild, we ran the campaigns, shot the creative, and produced the content that filled the funnel. Full case study coming soon.
          </p>
        </div>

        <div class="mt-14 grid gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/5 md:grid-cols-2 lg:grid-cols-4">
          {beyond.map((b) => (
            <article class="flex flex-col bg-black p-7 transition-colors hover:bg-white/[0.03] md:p-8">
              <span class="inline-flex w-fit items-center gap-2 rounded-full border border-gold-soft/30 bg-gold-soft/5 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.18em] text-gold-soft">
                Case study soon
              </span>
              <h3 class="mt-6 font-display text-xl font-medium leading-tight">{b.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-white/60">{b.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== NEXT / BACK ========== -->
    <section class="bg-white py-16 md:py-20">
      <div class="container-x">
        <div class="flex flex-col items-start justify-between gap-6 border-t border-black/10 pt-10 sm:flex-row sm:items-center">
          <a href="/website-design" class="inline-flex items-center gap-2 text-sm font-medium text-ink/70 transition-colors hover:text-gold">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M11 6H1m0 0l5-5M1 6l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All website projects
          </a>
          <a href="https://www.neadjustment.com/" target="_blank" rel="noopener" class="btn-secondary">
            Visit neadjustment.com
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M4 8L8 4M8 4H4M8 4V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</BaseLayout>
