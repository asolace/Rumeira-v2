---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter((h) => h.depth === 2);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const related = allPosts
  .filter((p) => p.id !== post.id)
  .filter((p) => p.data.tags.some((t) => post.data.tags.includes(t)))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const wordCount = typeof post.body === 'string' ? post.body.split(/\s+/).filter(Boolean).length : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 220));

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const canonical = `https://rumeira.com/blog/${post.id}`;
---

<BaseLayout
  title={`${post.data.title} | Rumeira`}
  description={post.data.description}
  canonical={canonical}
>
  <Nav />
  <main id="main">

    <!-- ========== POST HERO ========== -->
    <article>
      <header class="relative overflow-hidden bg-white pt-32 pb-12 md:pt-40 md:pb-16">
        <div class="pointer-events-none absolute inset-0 bg-grid-light opacity-60 [mask-image:radial-gradient(ellipse_at_top_left,black_20%,transparent_70%)]"></div>
        <div class="pointer-events-none absolute -top-32 left-[-10%] h-[560px] w-[560px] rounded-full bg-gold/15 blur-3xl"></div>

        <div class="container-x relative">
          <a href="/blog" class="inline-flex items-center gap-2 text-sm text-ink/50 transition-colors hover:text-gold">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M11 6H1m0 0l5-5M1 6l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All posts
          </a>

          <div class="mt-8 max-w-3xl">
            <div class="flex flex-wrap gap-1.5">
              {post.data.tags.map((t) => (
                <span class="rounded-full bg-ink/[0.06] px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.18em] text-ink/70">
                  {t}
                </span>
              ))}
            </div>

            <h1 class="mt-6 font-display text-4xl font-bold leading-[1.05] tracking-tightest text-ink sm:text-5xl md:text-6xl">
              {post.data.title}
            </h1>
            <p class="mt-6 text-balance text-lg leading-relaxed text-ink/65 md:text-xl">
              {post.data.description}
            </p>

            <div class="mt-10 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-black/10 pt-6 text-sm text-ink/60">
              <span class="font-medium text-ink">{post.data.author}</span>
              <span class="text-ink/30">·</span>
              <span>{fmtDate(post.data.publishedAt)}</span>
              {readingMinutes > 0 && (
                <>
                  <span class="text-ink/30">·</span>
                  <span>{readingMinutes} min read</span>
                </>
              )}
            </div>
          </div>
        </div>
      </header>

      <!-- ========== COVER IMAGE ========== -->
      <section class="bg-white pb-12 md:pb-16">
        <div class="container-x">
          <figure class="mx-auto w-fit max-w-full overflow-hidden rounded-3xl border border-black/10 bg-[#F3F4F6] shadow-[0_40px_120px_-50px_rgba(0,0,0,0.35)]">
            <img
              src={post.data.coverImage}
              alt={post.data.coverImageAlt ?? post.data.title}
              width="1600"
              height="1000"
              class="block max-h-96 w-auto"
              loading="eager"
            />
          </figure>
        </div>
      </section>

      <!-- ========== ARTICLE BODY ========== -->
      <section class="bg-white pb-24 md:pb-32">
        <div class="container-x">
          <div class="mx-auto max-w-3xl lg:flex lg:max-w-5xl lg:gap-12 xl:gap-16">
            {tocHeadings.length > 0 && (
              <aside class="hidden lg:block lg:w-52 lg:flex-none">
                <nav class="sticky top-28" aria-label="Table of contents">
                  <div class="text-xs uppercase tracking-[0.2em] text-ink/40">On this page</div>
                  <ul class="mt-5 space-y-1 border-l border-black/10">
                    {tocHeadings.map((h) => (
                      <li>
                        <a
                          href={`#${h.slug}`}
                          class="block -ml-px border-l-2 border-transparent py-1.5 pl-4 text-sm leading-snug text-ink/55 transition-colors hover:border-gold hover:text-ink"
                        >
                          {h.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </aside>
            )}
            <div class="prose-rumeira lg:flex-1 lg:max-w-3xl">
              <Content />
            </div>
          </div>
        </div>
      </section>
    </article>

    <!-- ========== RELATED POSTS ========== -->
    {related.length > 0 && (
      <section class="bg-[#FBF8EF] py-20 md:py-28">
        <div class="container-x">
          <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
            <div class="max-w-2xl">
              <span class="eyebrow">
                <span class="h-px w-6 bg-gold"></span>
                Keep reading
              </span>
              <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
                Related posts.
              </h2>
            </div>
            <a href="/blog" class="group inline-flex flex-none items-center gap-2 text-sm font-medium text-ink/70 transition-colors hover:text-gold">
              All posts
              <span class="flex h-7 w-7 items-center justify-center rounded-full border border-black/10 transition-all group-hover:border-gold group-hover:bg-gold group-hover:text-white">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M1 6h10m0 0L6 1m5 5L6 11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          </div>

          <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((p) => (
              <a
                href={`/blog/${p.id}`}
                class="group flex flex-col overflow-hidden rounded-2xl border border-black/10 bg-white transition-all duration-300 hover:border-gold/40 hover:shadow-[0_30px_80px_-30px_rgba(152,118,34,0.25)]"
              >
                <div class="relative aspect-[16/10] overflow-hidden bg-gradient-to-br from-ink/[0.06] to-ink/[0.02]">
                  <img
                    src={p.data.coverImage}
                    alt={p.data.coverImageAlt ?? p.data.title}
                    width="800"
                    height="500"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <div class="flex flex-wrap gap-1.5">
                    {p.data.tags.map((t) => (
                      <span class="rounded-full bg-ink/[0.06] px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.18em] text-ink/70">
                        {t}
                      </span>
                    ))}
                  </div>
                  <h3 class="mt-4 font-display text-xl font-medium leading-tight text-ink md:text-2xl">
                    {p.data.title}
                  </h3>
                  <p class="mt-3 text-sm leading-relaxed text-ink/60">
                    {p.data.description}
                  </p>
                  <div class="mt-6 flex items-center justify-between border-t border-black/10 pt-4 text-xs text-ink/50">
                    <span>{fmtDate(p.data.publishedAt)}</span>
                    <span class="inline-flex items-center gap-1.5 font-medium text-gold">
                      Read
                      <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <CTA />
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .prose-rumeira {
    color: rgb(17 17 17 / 0.78);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-rumeira > * + * { margin-top: 1.5rem; }
  html { scroll-behavior: smooth; }
  .prose-rumeira h2 {
    font-family: var(--font-display, 'Clash Display', system-ui, sans-serif);
    font-weight: 500;
    color: rgb(17 17 17);
    font-size: 2rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
    scroll-margin-top: 6rem;
  }
  .prose-rumeira h3 {
    font-family: var(--font-display, 'Clash Display', system-ui, sans-serif);
    font-weight: 500;
    color: rgb(17 17 17);
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-rumeira p { margin-top: 1.25rem; }
  .prose-rumeira a {
    color: rgb(152 118 34);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }
  .prose-rumeira a:hover { color: rgb(17 17 17); }
  .prose-rumeira strong { color: rgb(17 17 17); font-weight: 600; }
  .prose-rumeira ul, .prose-rumeira ol { padding-left: 1.5rem; margin-top: 1.25rem; }
  .prose-rumeira ul { list-style: disc; }
  .prose-rumeira ol { list-style: decimal; }
  .prose-rumeira li { margin-top: 0.5rem; padding-left: 0.25rem; }
  .prose-rumeira li::marker { color: rgb(152 118 34); }
  .prose-rumeira blockquote {
    border-left: 3px solid rgb(152 118 34);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 2rem 0;
    color: rgb(17 17 17 / 0.85);
    font-style: italic;
  }
  .prose-rumeira code {
    background: rgb(17 17 17 / 0.06);
    color: rgb(17 17 17);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
  }
  .prose-rumeira pre {
    background: rgb(17 17 17);
    color: rgb(255 255 255 / 0.92);
    padding: 1.25rem 1.5rem;
    border-radius: 1rem;
    overflow-x: auto;
    margin: 1.75rem 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .prose-rumeira pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }
  .prose-rumeira hr {
    border: 0;
    border-top: 1px solid rgb(17 17 17 / 0.1);
    margin: 3rem 0;
  }
  .prose-rumeira img {
    border-radius: 1rem;
    margin: 2rem 0;
  }
  .prose-rumeira img.small  { max-width: 320px; margin-left: auto; margin-right: auto; }
  .prose-rumeira img.medium { max-width: 560px; margin-left: auto; margin-right: auto; }
  .prose-rumeira img.large  { max-width: 100%; }
  .prose-rumeira figure {
    margin: 2rem 0;
  }
  .prose-rumeira figure img {
    margin: 0 auto;
  }
  .prose-rumeira figcaption {
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgb(17 17 17 / 0.5);
    margin-top: 0.75rem;
  }
</style>
