---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';

// -----------------------------------------------------------------------------
// Image assets expected at /public/images/projects/agency-pm-suite/
// Drop the files in and they will render automatically.
//
//   thumbnail.webp          - used by the /software-development grid card (1200x900)
//   hero.webp               - main board / dashboard screenshot (1600x1000)
//   client-management.webp  - client list or client detail view
//   tasks.webp              - task board / one of the task views
//   task-views.webp         - the four view types (list, table, cards, calendar)
//   task-templates.webp     - template creation or application UI
//   leads-pipeline.webp     - leads board / lead detail
//   team-roles.webp         - team management / role assignment
//   client-portal.webp      - client-facing portal view
// -----------------------------------------------------------------------------

// NOTE: replace LIVE_URL with the real link when ready.
const LIVE_URL = '#';

const meta = [
  { k: 'Type', v: 'Project Management' },
  { k: 'Built for', v: 'Agency workflows' },
  { k: 'Built with', v: 'AI (zero manual code)' },
  {
    k: 'Replaces',
    items: ['ClickUp', 'Monday.com', 'Notion'],
  },
];

const features = [
  {
    id: 'client-management',
    eyebrow: 'Feature · Client Management',
    title: 'Every client gets their own space.',
    body: 'Each client has a dedicated project space with details, links, and notes in one place. Clients get a portal of their own, with selective visibility into the tasks and updates you choose to share.',
    bullets: [
      'Per-client project space',
      'Details, links, and internal notes',
      'Selective client portal access',
      'Built-in commenting and requests',
    ],
    img: '/images/projects/agency-pm-suite/hero.webp',
  },
  {
    id: 'tasks',
    eyebrow: 'Feature · Task Management',
    title: 'Tasks, four ways.',
    body: 'Every task supports priority, due date, labels, and subtasks. View the same tasks as a list, table, kanban cards, or calendar. Tasks without due dates sit in their own panel, ready to be dragged onto the calendar when they need a slot.',
    bullets: [
      'Priority, due dates, labels, subtasks',
      'List, table, cards, and calendar views',
      'Unscheduled panel with drag-to-calendar',
      'Project-level assignment to team members',
    ],
    img: '/images/projects/agency-pm-suite/calender-details.webp',
  },
  {
    id: 'task-templates',
    eyebrow: 'Feature · Task Templates',
    title: 'Build the playbook once.',
    body: 'Pre-build task lists for the workflows you run on every client -onboarding, monthly delivery, quarterly review. Add a new client, apply the template, and the whole task list populates instantly. No rebuilding the same checklist from scratch every time.',
    bullets: [
      'Reusable task groups',
      'One-click apply on new clients',
      'Editable per client after applying',
      'Standardize agency processes',
    ],
    img: '/images/projects/agency-pm-suite/task-template.webp',
  },
  {
    id: 'leads',
    eyebrow: 'Feature · Leads Pipeline',
    title: 'Leads in. Clients out. No copy-paste.',
    body: 'Leads are tracked separately from active clients, with their own pipeline. When a deal is closed, the lead converts into a client automatically -contact info, notes, and history move over without manual data entry.',
    bullets: [
      'Separate lead pipeline',
      'Auto-conversion on close',
      'Lead notes carry over to client',
      'No duplicate records, no copy-paste',
    ],
    img: '/images/projects/agency-pm-suite/leads.webp',
  },
  {
    id: 'team-roles',
    eyebrow: 'Feature · Team & Roles',
    title: 'Owner, manager, employee. Different views, different access.',
    body: 'Team members are invited with one of three roles. Owners and managers see everything; employees see only the tasks assigned to them, not entire client projects. Domain restrictions control who can be invited in the first place.',
    bullets: [
      'Three roles: owner, manager, employee',
      'Employee dashboard scoped to assigned tasks',
      'Project-level assignment to team members',
      'Domain-restricted invites',
    ],
    img: '/images/projects/agency-pm-suite/employee.webp',
  },
  {
    id: 'client-portal',
    eyebrow: 'Feature · Client Portal',
    title: 'Clients see exactly what you want them to see.',
    body: 'Clients log in with their own account into a portal designed for them. You control which tasks they can see, comment on, and respond to. They can submit new requests directly, which land in the activity feed so nothing slips through Slack or email.',
    bullets: [
      'Per-client login and portal',
      'Selective task sharing',
      'Client comments and request submissions',
      'Everything captured in the activity feed',
    ],
    img: '/images/projects/agency-pm-suite/client-requests.jpg',
  },
];

// Other case studies shown at the bottom (excludes the current project).
const featured: Array<{
  slug?: string;
  name?: string;
  category?: string;
  result?: string;
  thumbnail?: string;
  href?: string;
  placeholder?: boolean;
}> = [
  { placeholder: true, category: 'Software build' },
  { placeholder: true, category: 'Software build' },
  { placeholder: true, category: 'Software build' },
];
---

<BaseLayout
  title="Agency PM Suite | Software Project · Rumeira"
  description="A custom project management tool built for agency workflows. Client management, tasks, leads, team roles, and a client portal in one place. Built end-to-end with AI to replace the ClickUp, Monday.com, and Notion patchwork."
  canonical="https://rumeira.com/software-project/agency-pm-suite"
>
  <Nav />
  <main id="main">

    <!-- ========== HERO ========== -->
    <section class="relative overflow-hidden bg-white pt-32 pb-16 md:pt-40 md:pb-20">
      <div class="pointer-events-none absolute inset-0 bg-grid-light opacity-60 [mask-image:radial-gradient(ellipse_at_top_left,black_20%,transparent_70%)]"></div>
      <div class="pointer-events-none absolute -top-32 left-[-10%] h-[560px] w-[560px] rounded-full bg-gold/15 blur-3xl"></div>

      <div class="container-x relative">
        <a href="/software-development" class="inline-flex items-center gap-2 text-sm text-ink/50 transition-colors hover:text-gold">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M11 6H1m0 0l5-5M1 6l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All case studies
        </a>

        <div class="mt-8 grid items-end gap-10 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-8">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Software Project · Internal Tool
            </span>
            <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tightest text-ink sm:text-6xl md:text-7xl">
              Agency PM Suite
            </h1>
            <p class="mt-7 max-w-2xl text-balance text-lg leading-relaxed text-ink/65 md:text-xl">
              A custom project management tool built for agency workflows. Client management, tasks, leads, team roles, and a client portal in one place. Built entirely through <span class="font-medium text-ink">AI</span> to replace the ClickUp, Monday.com, and Notion patchwork most agencies have outgrown.
            </p>
          </div>

          <div class="lg:col-span-4 text-right">
            <a href={LIVE_URL} target="_blank" rel="noopener" class="btn-primary w-full sm:w-auto">
              Visit live tool
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M5 9L9 5M9 5H5M9 5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="1.5" y="1.5" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="mt-14 grid grid-cols-2 gap-6 border-t border-black/10 pt-8 md:grid-cols-4">
          {meta.map((m) => (
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-ink/70">{m.k}</div>
              {m.items ? (
                <ul class="mt-2 flex flex-wrap gap-1.5">
                  {m.items.map((item) => (
                    <li class="rounded-full bg-ink/[0.06] px-2.5 py-1 text-xs font-medium text-ink/80">{item}</li>
                  ))}
                </ul>
              ) : (
                <div class="mt-2 text-sm font-medium text-ink">{m.v}</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== HERO IMAGE ========== -->
    <section class="bg-white pb-16 md:pb-24">
      <div class="container-x">
        <figure class="overflow-hidden rounded-3xl border border-black/10 bg-[#F3F4F6] shadow-[0_40px_120px_-50px_rgba(0,0,0,0.35)]">
          <img
            src="/images/projects/agency-pm-suite/hero.webp"
            alt="Agency PM Suite main dashboard"
            width="1600"
            height="1000"
            class="block w-full h-auto"
            loading="eager"
          />
        </figure>
      </div>
    </section>

    <!-- ========== THE WHY ========== -->
    <section class="bg-white py-20 md:py-28">
      <div class="container-x">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-5">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              The why
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
              We built it because nothing on the market fit.
            </h2>
          </div>
          <div class="space-y-6 text-base leading-relaxed text-ink/70 md:text-lg lg:col-span-7">
            <p>
              Most project management tools are built for everyone, which means they are never quite right for anyone. ClickUp, Monday.com, and Notion are packed with features that get in the way -and the parts an agency actually needs (lead tracking, scoped employee views, a real client portal) were always one paywall up or one workaround away.
            </p>
            <p>
              We needed a single space where <span class="font-medium text-ink">leads, clients, tasks, team roles, and client requests</span> all live and talk to each other. Shaped to the way an agency actually runs, not how a generic product roadmap thinks it should. So we built it.
            </p>
            <div class="grid grid-cols-3 gap-4 border-t border-black/10 pt-6">
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">10<span class="text-gold">+</span></div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Core features</div>
              </div>
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">3</div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">User roles</div>
              </div>
              <div>
                <div class="font-display text-2xl font-medium text-ink md:text-3xl">4</div>
                <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Task views</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== BUILT WITH AI ========== -->
    <section class="bg-white pb-20 md:pb-28">
      <div class="container-x">
        <div class="overflow-hidden rounded-3xl border border-black/10 bg-[#FBF8EF]">
          <div class="grid gap-10 p-8 md:grid-cols-12 md:gap-16 md:p-12">
            <div class="md:col-span-7">
              <span class="eyebrow">
                <span class="h-px w-6 bg-gold"></span>
                The build
              </span>
              <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-4xl lg:text-5xl">
                Built end-to-end with <span class="text-gold">AI.</span>
              </h2>
              <p class="mt-6 max-w-xl text-base leading-relaxed text-ink/65 md:text-lg">
                Every screen, every component, every database query was generated and iterated through AI. Zero manual line-by-line coding. The whole tool is a proof of what is possible when you treat AI as the engineering team -and a preview of how we build software for clients.
              </p>
            </div>
            <div class="md:col-span-5">
              <div class="grid grid-cols-2 gap-3">
                <div class="rounded-2xl border border-black/10 bg-white p-5">
                  <div class="font-display text-3xl font-medium text-gold md:text-4xl">0</div>
                  <div class="mt-2 text-xs uppercase tracking-[0.18em] text-ink/50">Manual lines</div>
                </div>
                <div class="rounded-2xl border border-black/10 bg-white p-5">
                  <div class="font-display text-3xl font-medium text-gold md:text-4xl">100<span class="text-xl md:text-2xl">%</span></div>
                  <div class="mt-2 text-xs uppercase tracking-[0.18em] text-ink/50">AI-generated</div>
                </div>
                <div class="rounded-2xl border border-black/10 bg-white p-5">
                  <div class="font-display text-2xl font-medium text-ink md:text-3xl">TS</div>
                  <div class="mt-2 text-xs uppercase tracking-[0.18em] text-ink/50">TypeScript + React</div>
                </div>
                <div class="rounded-2xl border border-black/10 bg-white p-5">
                  <div class="font-display text-2xl font-medium text-ink md:text-3xl">FB</div>
                  <div class="mt-2 text-xs uppercase tracking-[0.18em] text-ink/50">Firebase</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== FEATURE DEEP DIVES ========== -->
    {features.map((f, i) => {
      const reverse = i % 2 === 1;
      const bg = i % 2 === 0 ? 'bg-[#FBF8EF]' : 'bg-white';
      return (
        <section id={f.id} class={`${bg} py-20 md:py-28`}>
          <div class="container-x">
            <div class={`grid gap-10 lg:grid-cols-12 lg:gap-16 ${reverse ? 'lg:[&>figure]:order-2' : ''}`}>
              <div class="lg:col-span-5">
                <span class="eyebrow">
                  <span class="h-px w-6 bg-gold"></span>
                  {f.eyebrow}
                </span>
                <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-4xl lg:text-5xl">
                  {f.title}
                </h2>
                <p class="mt-6 text-base leading-relaxed text-ink/65 md:text-lg">
                  {f.body}
                </p>
                <ul class="mt-8 space-y-3 border-t border-black/10 pt-6">
                  {f.bullets.map((b) => (
                    <li class="flex items-start gap-3 text-sm text-ink/75 md:text-base">
                      <svg class="mt-1 h-3 w-3 flex-none text-gold" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M2 6.5L5 9.5L10 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <figure class="overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_30px_80px_-40px_rgba(0,0,0,0.25)] lg:col-span-7">
                <img
                  src={f.img}
                  alt={f.title}
                  width="1200"
                  height="800"
                  class="block w-full h-auto"
                  loading="lazy"
                />
              </figure>
            </div>
          </div>
        </section>
      );
    })}

    <!-- ========== OTHER CASE STUDIES ========== -->
    <section class="bg-white py-20 md:py-28">
      <div class="container-x">
        <div class="flex flex-col items-start justify-between gap-6 border-t border-black/10 pt-12 sm:flex-row sm:items-end">
          <div class="max-w-2xl">
            <span class="eyebrow">
              <span class="h-px w-6 bg-gold"></span>
              Other case studies
            </span>
            <h2 class="mt-5 font-display text-3xl font-medium leading-[1.1] tracking-tight md:text-5xl">
              More work,<br/>
              <span class="text-gold">same engine.</span>
            </h2>
          </div>
          <a href="/software-development" class="group inline-flex flex-none items-center gap-2 text-sm font-medium text-ink/70 transition-colors hover:text-gold">
            Back to Software Development
            <span class="flex h-7 w-7 items-center justify-center rounded-full border border-black/10 transition-all group-hover:border-gold group-hover:bg-gold group-hover:text-white">
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M1 6h10m0 0L6 1m5 5L6 11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>

        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((p) => p.placeholder ? (
            <div class="relative flex flex-col overflow-hidden rounded-2xl border border-dashed border-black/15 bg-[#FBF8EF]/40">
              <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-ink/[0.04] to-ink/[0.02]">
                <div class="flex h-full items-center justify-center text-xs uppercase tracking-[0.18em] text-ink/30">
                  Coming soon
                </div>
              </div>
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-xl font-medium leading-tight text-ink/40">New case study shipping soon</h3>
                <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-ink/30">
                  <span class="h-px w-4 bg-ink/20"></span>
                  {p.category}
                </div>
              </div>
            </div>
          ) : (
            <a href={p.href ?? `/software-project/${p.slug}`} class="group relative flex flex-col overflow-hidden rounded-2xl border border-black/10 bg-white transition-all duration-300 hover:border-gold/40 hover:shadow-[0_30px_80px_-30px_rgba(152,118,34,0.25)]">
              <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-ink/[0.04] to-ink/[0.02]">
                {p.thumbnail ? (
                  <img src={p.thumbnail} alt={p.name} width="800" height="600" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" loading="lazy" />
                ) : (
                  <div class="flex h-full items-center justify-center text-xs uppercase tracking-[0.18em] text-ink/30">Preview</div>
                )}
                <span class="absolute left-4 top-4 rounded-full bg-gold text-white px-3 py-1 text-[10px] font-medium uppercase tracking-[0.18em] text-ink/70 backdrop-blur">
                  {p.category}
                </span>
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-start justify-between gap-4">
                  <h3 class="font-display text-xl font-medium leading-tight">{p.name}</h3>
                  <span class="mt-1 flex h-7 w-7 flex-none items-center justify-center rounded-full border border-black/10 text-ink/40 transition-all group-hover:border-gold group-hover:bg-gold group-hover:text-white">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M1 6h10m0 0L6 1m5 5L6 11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
                <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-gold">
                  <span class="h-px w-4 bg-gold"></span>
                  {p.result}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</BaseLayout>
