---
const cols = [
  {
    title: 'Services',
    links: [
      { href: '#services', label: 'Digital Marketing' },
      { href: '#services', label: 'Website Design' },
      { href: '#services', label: 'AI Strategy' },
      { href: '#process', label: 'Process' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '#why', label: 'Why Rumeira' },
      { href: '#results', label: 'Results' },
      { href: '#cta', label: 'Contact' },
      { href: 'https://pm.rumeira.com', label: 'Client login' },
    ],
  },
  {
    title: 'Contact',
    links: [
      { href: 'mailto:start@rumeira.com', label: 'start@rumeira.com' },
      { href: '#cta', label: 'Book a call' },
      { href: '#cta', label: 'Get a free audit' },
    ],
  },
];

const socials = [
  { href: 'https://www.facebook.com/rumeira', label: 'Facebook' },
  { href: 'https://www.instagram.com/rumeira', label: 'Instagram' },
  { href: 'https://www.linkedin.com/company/rumeira', label: 'LinkedIn' },
  { href: 'https://x.com/rumeira', label: 'X' },
  { href: 'https://www.tiktok.com/@rumeira', label: 'TikTok' },
  { href: 'https://www.youtube.com/@rumeira', label: 'YouTube' },
];

const year = new Date().getFullYear();
---

<footer class="bg-black text-white">
  <div class="container-x pb-20 pt-36 md:pb-28 md:pt-40">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <a href="/" aria-label="Rumeira">
          <img
            src="/images/Rumeira Brand Right - White Text.svg"
            alt="Rumeira"
            width="160"
            height="48"
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
        </a>
        <p class="mt-6 max-w-sm text-sm leading-relaxed text-white/55">
          Digital marketing, conversion-driven websites, and AI workflow systems engineered as one growth engine.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          {socials.map((s) => (
            <a href={s.href} aria-label={s.label} class="rounded-full border border-white/15 px-4 py-2 text-xs text-white/70 transition-colors hover:border-gold hover:text-gold">
              {s.label}
            </a>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 gap-10 md:col-span-7 md:grid-cols-3">
        {cols.map((c) => (
          <div>
            <h4 class="text-xs uppercase tracking-[0.2em] text-white/40">{c.title}</h4>
            <ul class="mt-5 space-y-3">
              {c.links.map((l) => (
                <li>
                  <a href={l.href} class="text-sm text-white/75 transition-colors hover:text-gold">{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 text-xs text-white/40 md:flex-row md:items-center">
      <p>© {year} Rumeira. All rights reserved.</p>
      <p>Search Everywhere Optimization · Generative Engine Optimization · AI Workflows</p>
    </div>
  </div>
</footer>
