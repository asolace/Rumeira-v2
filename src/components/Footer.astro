---
export interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;

const cols = [
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About' },
      { href: '/careers', label: 'Careers' },
      { href: '/blog', label: 'Blogs' },
    ],
  },
  {
    title: 'Solutions',
    links: [
      { href: '#services', label: 'Digital Marketing' },
      { href: '#services', label: 'Website Design' },
      { href: '#', label: 'Software Development' },
      // { href: '#services', label: 'AI Strategy' },
    ],
  },
  {
    title: 'Services',
    links: [
      { href: '#', label: 'On-Page SEO' },
      { href: '#', label: 'Facebook Ads' },
      { href: '#', label: 'Google Ads' },
      { href: '#', label: 'GBP Setup' },
      { href: '#', label: 'Google Map Rank' },
      { href: '#', label: 'Link Building' },
      { href: '#', label: 'AI Visibility' },
      { href: '#', label: 'AI Website' },
      { href: '#', label: 'Website Audit' },
      { href: '#', label: 'Brand Audit' },
    ],
  },
  {
    title: 'Membership',
    links: [
      { href: '#', label: 'Analytics' },
      { href: '#', label: 'Resources' },
      { href: '#', label: 'Research' },
      { href: '#', label: 'Concepts' },
      { href: '#', label: 'Development' },
      { divider: true },
      { href: 'https://pm.rumeira.com/#client', label: 'Client Login' },
      { href: 'https://pm.rumeira.com', label: 'Staff Login' },
    ],
  },
];

const legal = [
  { href: '/terms-conditions', label: 'Terms & Conditions' },
  { href: '/terms-of-service', label: 'Terms of Service' },
  { href: '/refund-policy', label: 'Refund Policy' },
  { href: '/privacy-policy', label: 'Privacy Policy' },
  { href: '/cookies-policy', label: 'Cookies Policy' },
];

const certifications = [
  { src: '/images/gsa-accelerator-final-white.webp', alt: 'GSA Accelerator Certified' },
  { src: '/images/gsa-specialist-final-white.webp', alt: 'GSA Specialist Certified' },
  { src: '/images/gsa-expert-final-white.webp', alt: 'GSA Expert Certified' },
  { src: '/images/gsa-master-final-white.webp', alt: 'GSA Master Certified' },
  { src: '/images/Semrush Certification.png', alt: 'Semrush Certified' },
];

const socials = [
  { href: 'https://www.facebook.com/rumeira', label: 'Facebook', icon: '/images/facebook-logo.svg' },
  { href: 'https://www.instagram.com/rumeira', label: 'Instagram', icon: '/images/instagram-logo.svg' },
  { href: 'https://www.linkedin.com/company/rumeira', label: 'LinkedIn', icon: '/images/linkedin-logo.svg' },
  { href: 'https://x.com/rumeira', label: 'X', icon: '/images/x-logo-white.svg' },
  { href: 'https://www.tiktok.com/@rumeira', label: 'TikTok', icon: '/images/tiktok-logo.svg' },
  { href: 'https://www.youtube.com/@rumeira', label: 'YouTube', icon: '/images/youtube-logo.svg' },
];

const year = new Date().getFullYear();
---

<footer class="bg-black text-white">
  <div class:list={["container-x pb-20 pt-36 md:pb-28 md:pt-40"]}>
    <div class="grid gap-12 md:grid-cols-12">
      <div class:list={["min-w-[276px]", minimal ? "md:col-span-12" : "md:col-span-4"]}>
        <a href="/" aria-label="Rumeira">
          <img
            src="/images/Rumeira Brand Right - White Text.svg"
            alt="Rumeira"
            width="160"
            height="48"
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
        </a>
        <p class="mt-6 max-w-sm text-sm leading-relaxed text-white/55">
          Digital marketing, conversion-driven websites, and AI workflow systems engineered as one growth engine.
        </p>
        <a
          href="mailto:start@rumeira.com"
          class="mt-8 inline-block text-lg font-bold text-white underline decoration-2 underline-offset-[6px] transition-colors hover:text-gold"
        >
          start@rumeira.com
        </a>

        {!minimal && (
          <div class="mt-6 flex flex-wrap gap-3">
            {socials.map((s) => (
              <a
                href={s.href}
                aria-label={s.label}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-9 w-9 items-center transition-transform duration-300 hover:scale-110"
              >
                <img src={s.icon} alt="" width="22" height="22" class="h-[22px] w-[22px] object-contain" loading="lazy" />
              </a>
            ))}
          </div>
        )}
      </div>

      {!minimal && (
        <div class="grid grid-cols-2 gap-10 md:col-span-8 md:grid-cols-4">
          {cols.map((c) => (
            <div>
              <h4 class="text-xs uppercase tracking-[0.2em] text-white/40">{c.title}</h4>
              <ul class="mt-5 space-y-3">
                {c.links.map((l) => (
                  l.divider ? (
                    <li aria-hidden="true" class="py-1"><hr class="border-t border-white/15" /></li>
                  ) : (
                    <li>
                      <a href={l.href} class="text-sm text-white transition-colors hover:text-gold">{l.label}</a>
                    </li>
                  )
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}
    </div>

    <div class="mt-16 flex flex-wrap items-center gap-x-6 gap-y-6">
      {certifications.map((c) => (
        <img
          src={c.src}
          alt={c.alt}
          class="h-16 w-auto object-contain opacity-80 transition-opacity hover:opacity-100 md:h-20"
          loading="lazy"
        />
      ))}
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 text-xs text-white md:flex-row ">
      <div class="leading-relaxed">
        <p class="mb-2">Rumeira digital marketing, website design and software development in New York, Texas, Florida</p>
        <p>Rumeira is an exclusive digital marketing & web design company located in New York.</p>
        <p>Rumeira has been fine tuning their marketing services to be the best.</p>
        <p>Rumeira specialize in website development and AI-targeted SEO services.</p>
      </div>

      <p>© {year} Rumeira. All rights reserved.</p>
    </div>

    <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2 pt-6 text-xs text-white">
      {legal.map((l, i) => (
        <>
          {i > 0 && <span aria-hidden="true" class="h-2 w-px bg-white"></span>}
          <a href={l.href} class="underline decoration-1 underline-offset-[6px] transition-colors hover:text-gold">{l.label}</a>
        </>
      ))}
    </div>
  </div>
</footer>
