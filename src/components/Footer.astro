---
const cols = [
  {
    title: 'Services',
    links: [
      { href: '#services', label: 'Digital Marketing' },
      { href: '#services', label: 'Website Design' },
      { href: '#services', label: 'AI Strategy' },
      { href: '#process', label: 'Process' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '#why', label: 'Why Rumeira' },
      { href: '#results', label: 'Results' },
      { href: '#cta', label: 'Contact' },
      { href: 'https://pm.rumeira.com', label: 'Client login' },
    ],
  },
  {
    title: 'Contact',
    links: [
      { href: 'mailto:start@rumeira.com', label: 'start@rumeira.com' },
      { href: '#cta', label: 'Book a call' },
      { href: '#cta', label: 'Get a free audit' },
    ],
  },
];

const socials = [
  { href: 'https://www.facebook.com/rumeira', label: 'Facebook', icon: '/images/facebook-logo.svg' },
  { href: 'https://www.instagram.com/rumeira', label: 'Instagram', icon: '/images/instagram-logo.svg' },
  { href: 'https://www.linkedin.com/company/rumeira', label: 'LinkedIn', icon: '/images/linkedin-logo.svg' },
  { href: 'https://x.com/rumeira', label: 'X', icon: '/images/x-logo-white.svg' },
  { href: 'https://www.tiktok.com/@rumeira', label: 'TikTok', icon: '/images/tiktok-logo.svg' },
  { href: 'https://www.youtube.com/@rumeira', label: 'YouTube', icon: '/images/youtube-logo.svg' },
];

const year = new Date().getFullYear();
---

<footer class="bg-black text-white">
  <div class="container-x pb-20 pt-36 md:pb-28 md:pt-40">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <a href="/" aria-label="Rumeira">
          <img
            src="/images/Rumeira Brand Right - White Text.svg"
            alt="Rumeira"
            width="160"
            height="48"
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
        </a>
        <p class="mt-6 max-w-sm text-sm leading-relaxed text-white/55">
          Digital marketing, conversion-driven websites, and AI workflow systems engineered as one growth engine.
        </p>
        <a
          href="mailto:start@rumeira.com"
          class="mt-8 inline-block font-bold text-white underline decoration-2 underline-offset-[6px] transition-colors hover:text-gold"
        >
          start@rumeira.com
        </a>

        <div class="mt-6 flex flex-wrap gap-4">
          {socials.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center transition-transform duration-300 hover:scale-110"
            >
              <img src={s.icon} alt="" width="22" height="22" class="h-[22px] w-[22px] object-contain" loading="lazy" />
            </a>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 gap-10 md:col-span-7 md:grid-cols-3">
        {cols.map((c) => (
          <div>
            <h4 class="text-xs uppercase tracking-[0.2em] text-white/40">{c.title}</h4>
            <ul class="mt-5 space-y-3">
              {c.links.map((l) => (
                <li>
                  <a href={l.href} class="text-sm text-white/75 transition-colors hover:text-gold">{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 text-xs text-white/80 md:flex-row ">
      <div class="leading-relaxed">
        <p class="mb-2">Rumeira digital marketing, website design and software development in New York, Texas, Florida</p>
        <p>Rumeira is an exclusive digital marketing & web design company located in New York.</p>
        <p>Rumeira has been fine tuning their marketing services to be the best.</p>
        <p>Rumeira specialize in website development and AI-targeted SEO services.</p>
      </div>

      <p>© {year} Rumeira. All rights reserved.</p>
    </div>
  </div>
</footer>
