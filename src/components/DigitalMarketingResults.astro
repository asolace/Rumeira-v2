---
// Add case studies here as they're written.
// Shape per case study:
// {
//   slug: 'project-name',     // becomes /digital-marketing-project/[slug]
//   name: 'Display Name',
//   category: 'SEO',          // or 'Paid' | 'Full-funnel' | 'Lifecycle' | etc.
//   result: 'short headline metric',
//   thumbnail: '/images/projects/project-name/thumbnail.webp',
// }
const caseStudies: Array<{
  slug: string;
  name: string;
  category: string;
  result: string;
  thumbnail?: string;
}> = [
  {
    slug: 'strictly-junk-removal',
    name: 'Strictly Junk Removal',
    category: 'Local SEO',
    result: 'Page 1 in 6 months · Top 3 in ChatGPT',
    thumbnail: '/images/projects/strictly-junk-removal/thumbnail.webp',
  },
];

const hasStudies = caseStudies.length > 0;
---

<section id="results" class="bg-[#FBF8EF] py-24 md:py-36">
  <div class="container-x">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div class="max-w-2xl">
        <span class="eyebrow">
          <span class="h-px w-6 bg-gold"></span>
          Case studies
        </span>
        <h2 class="mt-5 font-display text-4xl font-medium leading-[1.05] tracking-tight md:text-6xl">
          Programs we ran.<br/>
          <span class="text-gold">Numbers we hit.</span>
        </h2>
      </div>
      <p class="max-w-md text-base text-ink/60 md:text-lg">
        Each engagement below was run against the same four pillars. Different industries, different channels, different starting lines, same direction.
      </p>
    </div>

    {hasStudies ? (
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {caseStudies.map((p) => (
          <a
            href={`/digital-marketing-project/${p.slug}`}
            class="group relative flex flex-col overflow-hidden rounded-2xl border border-black/10 bg-white transition-all duration-300 hover:border-gold/40 hover:shadow-[0_30px_80px_-30px_rgba(152,118,34,0.25)]"
          >
            <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-ink/[0.04] to-ink/[0.02]">
              {p.thumbnail ? (
                <img
                  src={p.thumbnail}
                  alt={p.name}
                  width="800"
                  height="600"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-full items-center justify-center text-xs uppercase tracking-[0.18em] text-ink/30">
                  Preview
                </div>
              )}
              <span class="absolute left-4 top-4 rounded-full bg-gold text-white px-3 py-1 text-[10px] font-medium uppercase tracking-[0.18em] text-ink/70 backdrop-blur">
                {p.category}
              </span>
            </div>

            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-start justify-between gap-4">
                <h3 class="font-display text-xl font-medium leading-tight">{p.name}</h3>
                <span class="mt-1 flex h-7 w-7 flex-none items-center justify-center rounded-full border border-black/10 text-ink/40 transition-all group-hover:border-gold group-hover:bg-gold group-hover:text-white">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M1 6h10m0 0L6 1m5 5L6 11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-gold">
                <span class="h-px w-4 bg-gold"></span>
                {p.result}
              </div>
            </div>
          </a>
        ))}

        <!-- Placeholders for upcoming case studies -->
        <div class="relative flex flex-col overflow-hidden rounded-2xl border border-dashed border-black/15 bg-white/40">
          <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-ink/[0.04] to-ink/[0.02]">
            <div class="flex h-full items-center justify-center text-xs uppercase tracking-[0.18em] text-ink/30">Coming soon</div>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="font-display text-xl font-medium leading-tight text-ink/40">New case study shipping soon</h3>
            <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-ink/30">
              <span class="h-px w-4 bg-ink/20"></span>
              Case study
            </div>
          </div>
        </div>
        <div class="relative flex flex-col overflow-hidden rounded-2xl border border-dashed border-black/15 bg-white/40">
          <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-ink/[0.04] to-ink/[0.02]">
            <div class="flex h-full items-center justify-center text-xs uppercase tracking-[0.18em] text-ink/30">Coming soon</div>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="font-display text-xl font-medium leading-tight text-ink/40">New case study shipping soon</h3>
            <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-ink/30">
              <span class="h-px w-4 bg-ink/20"></span>
              Case study
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class="mt-16 rounded-2xl border border-dashed border-black/15 bg-white/40 p-12 text-center md:p-20">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-gold/10 text-gold">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 7h18M3 12h18M3 17h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="mt-6 font-display text-2xl font-medium md:text-3xl">Case studies are being written.</h3>
        <p class="mx-auto mt-4 max-w-md text-base text-ink/60 md:text-lg">
          We're documenting recent marketing engagements - the strategy, the channels, and the numbers. New studies publish every few weeks.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/get-started" class="btn-primary">
            Start your program
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    )}
  </div>
</section>
