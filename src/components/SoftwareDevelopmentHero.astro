---
---

<section class="relative overflow-hidden bg-white pt-32 pb-20 md:pt-40 md:pb-28">
  <div class="pointer-events-none absolute inset-0 bg-grid-light opacity-60 [mask-image:radial-gradient(ellipse_at_top_right,black_20%,transparent_70%)]"></div>
  <div class="pointer-events-none absolute -top-32 right-[-10%] h-[560px] w-[560px] rounded-full bg-gold/15 blur-3xl"></div>

  <div class="container-x relative">
    <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
      <!-- LEFT: copy -->
      <div class="lg:col-span-6 xl:col-span-7" style="max-width: 700px;">
        <span class="eyebrow">
          <span class="h-px w-6 bg-gold"></span>
          Software Development
        </span>

        <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tightest text-ink sm:text-6xl md:text-7xl lg:text-[5rem] xl:text-[5.5rem]">
          Software built for
          <span>
            <span class="bg-gradient-to-r from-gold via-gold-light to-gold bg-clip-text text-transparent">how you</span><span class="text-ink"> actually</span>
          </span>
          <span class="text-ink">work.</span>
        </h1>

        <p class="mt-7 max-w-xl text-balance text-lg leading-relaxed text-ink/65 md:text-xl">
          Custom internal web apps engineered on modern stacks. PM tools, CRMs, and dashboards that <span class="font-medium text-ink">fit your workflow</span> -not the other way around.
        </p>

        <div class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:gap-4">
          <a href="/get-started" class="btn-primary">
            Book a Strategy Call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#projects" class="btn-secondary">
            See Projects
          </a>
        </div>

        <div class="mt-12 grid grid-cols-3 gap-6 border-t border-black/10 pt-8">
          <div>
            <div class="font-display text-2xl font-medium text-ink md:text-3xl">100<span class="text-gold">%</span></div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Tailored to you</div>
          </div>
          <div>
            <div class="font-display text-2xl font-medium text-ink md:text-3xl">0</div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Roadmap waitlist</div>
          </div>
          <div>
            <div class="font-display text-2xl font-medium text-ink md:text-3xl">∞</div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Evolves with you</div>
          </div>
        </div>
      </div>

      <!-- RIGHT: kanban / PM tool composition -->
      <div class="relative lg:col-span-6 xl:col-span-5">
        <div class="relative mx-auto aspect-[5/6] w-full" style="max-width: 580px;">
          <div class="absolute inset-0 -z-10 rounded-[2rem] bg-gradient-to-br from-gold/20 via-gold-soft/10 to-transparent blur-2xl"></div>

          <!-- App frame -->
          <div class="absolute inset-x-0 top-[6%] rounded-2xl border border-black/[0.06] bg-white shadow-[0_40px_100px_-30px_rgba(0,0,0,0.3)]">
            <div class="flex items-center gap-1.5 border-b border-black/[0.06] px-4 py-3">
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <div class="ml-3 flex h-5 flex-1 items-center justify-between rounded-md bg-ink/[0.04] px-2">
                <span class="text-[8px] uppercase tracking-[0.2em] text-ink/40">Operations · Sprint 14</span>
                <span class="h-1.5 w-1.5 rounded-full bg-gold"></span>
              </div>
            </div>

            <div class="p-6">
              <!-- Top stats row -->
              <div class="grid grid-cols-3 gap-3">
                <div class="rounded-lg border border-black/[0.06] p-3">
                  <div class="text-[9px] uppercase tracking-wider text-ink/40">Sprints</div>
                  <div class="mt-1.5 font-display text-sm font-medium">4 active</div>
                </div>
                <div class="rounded-lg border border-black/[0.06] p-3">
                  <div class="text-[9px] uppercase tracking-wider text-ink/40">Open</div>
                  <div class="mt-1.5 font-display text-sm font-medium">27</div>
                </div>
                <div class="rounded-lg border border-black/[0.06] p-3">
                  <div class="text-[9px] uppercase tracking-wider text-ink/40">Velocity</div>
                  <div class="mt-1.5 font-display text-sm font-medium text-gold">+18%</div>
                </div>
              </div>

              <!-- Kanban columns -->
              <div class="mt-6 grid grid-cols-3 gap-2.5">
                <!-- To do -->
                <div>
                  <div class="flex items-center justify-between">
                    <span class="text-[8px] uppercase tracking-wider text-ink/40">To do</span>
                    <span class="text-[8px] font-medium text-ink/30">3</span>
                  </div>
                  <div class="mt-2 space-y-2">
                    <div class="rounded-md border border-black/[0.06] bg-white p-2">
                      <div class="h-1 w-8 rounded-full bg-ink/[0.15]"></div>
                      <div class="mt-1.5 h-1.5 w-full rounded-full bg-ink/[0.08]"></div>
                      <div class="mt-1 h-1.5 w-2/3 rounded-full bg-ink/[0.08]"></div>
                    </div>
                    <div class="rounded-md border border-black/[0.06] bg-white p-2">
                      <div class="h-1 w-6 rounded-full bg-ink/[0.15]"></div>
                      <div class="mt-1.5 h-1.5 w-full rounded-full bg-ink/[0.08]"></div>
                      <div class="mt-1 h-1.5 w-1/2 rounded-full bg-ink/[0.08]"></div>
                    </div>
                  </div>
                </div>

                <!-- In progress -->
                <div>
                  <div class="flex items-center justify-between">
                    <span class="text-[8px] uppercase tracking-wider text-gold">In progress</span>
                    <span class="text-[8px] font-medium text-gold">2</span>
                  </div>
                  <div class="mt-2 space-y-2">
                    <div class="rounded-md border border-gold/30 bg-gold/[0.04] p-2">
                      <div class="h-1 w-10 rounded-full bg-gold"></div>
                      <div class="mt-1.5 h-1.5 w-full rounded-full bg-ink/[0.1]"></div>
                      <div class="mt-1 h-1.5 w-3/4 rounded-full bg-ink/[0.1]"></div>
                      <div class="mt-2 flex items-center gap-1">
                        <span class="h-2 w-2 rounded-full bg-gold/70"></span>
                        <span class="h-2 w-2 -ml-1 rounded-full bg-gold/40 ring-1 ring-white"></span>
                      </div>
                    </div>
                    <div class="rounded-md border border-gold/30 bg-gold/[0.04] p-2">
                      <div class="h-1 w-8 rounded-full bg-gold"></div>
                      <div class="mt-1.5 h-1.5 w-full rounded-full bg-ink/[0.1]"></div>
                      <div class="mt-1 h-1.5 w-2/3 rounded-full bg-ink/[0.1]"></div>
                    </div>
                  </div>
                </div>

                <!-- Done -->
                <div>
                  <div class="flex items-center justify-between">
                    <span class="text-[8px] uppercase tracking-wider text-ink/40">Done</span>
                    <span class="text-[8px] font-medium text-ink/30">12</span>
                  </div>
                  <div class="mt-2 space-y-2">
                    <div class="rounded-md border border-black/[0.06] bg-ink/[0.02] p-2">
                      <div class="h-1 w-8 rounded-full bg-ink/[0.15]"></div>
                      <div class="mt-1.5 h-1.5 w-full rounded-full bg-ink/[0.06]"></div>
                      <div class="mt-1 h-1.5 w-1/2 rounded-full bg-ink/[0.06]"></div>
                    </div>
                    <div class="rounded-md border border-black/[0.06] bg-ink/[0.02] p-2">
                      <div class="h-1 w-6 rounded-full bg-ink/[0.15]"></div>
                      <div class="mt-1.5 h-1.5 w-full rounded-full bg-ink/[0.06]"></div>
                      <div class="mt-1 h-1.5 w-3/4 rounded-full bg-ink/[0.06]"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Module tiles -->
              <div class="mt-6 grid grid-cols-4 gap-2">
                <div class="rounded-md border border-black/[0.06] p-2 text-center">
                  <div class="text-[8px] uppercase tracking-wider text-ink/40">CRM</div>
                  <div class="mt-1 font-display text-[10px] font-medium text-gold">Live</div>
                </div>
                <div class="rounded-md border border-black/[0.06] p-2 text-center">
                  <div class="text-[8px] uppercase tracking-wider text-ink/40">PM</div>
                  <div class="mt-1 font-display text-[10px] font-medium text-gold">Live</div>
                </div>
                <div class="rounded-md border border-black/[0.06] p-2 text-center">
                  <div class="text-[8px] uppercase tracking-wider text-ink/40">Ops</div>
                  <div class="mt-1 font-display text-[10px] font-medium text-gold">Live</div>
                </div>
                <div class="rounded-md border border-black/[0.06] p-2 text-center">
                  <div class="text-[8px] uppercase tracking-wider text-ink/40">API</div>
                  <div class="mt-1 font-display text-[10px] font-medium text-gold">v2.1</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Deploy badge (top right) -->
          <div class="absolute -right-2 top-0 rotate-[4deg] rounded-2xl border border-black/[0.06] bg-white p-4 shadow-[0_20px_50px_-20px_rgba(0,0,0,0.25)]">
            <div class="flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-full bg-gold/10">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12l5 5 9-11" stroke="#987622" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-ink/40">Shipped</div>
                <div class="font-display text-sm font-medium">v1.4.0</div>
              </div>
            </div>
          </div>

          <!-- Realtime pill (bottom left) -->
          <div class="absolute -left-3 bottom-[4%] rotate-[-3deg] rounded-2xl border border-white/40 bg-black p-4 text-white shadow-[0_20px_50px_-20px_rgba(0,0,0,0.45)]">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2">
                <span class="absolute inline-flex h-2 w-2 animate-ping rounded-full bg-gold-soft opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-gold-soft"></span>
              </span>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-white/50">Realtime sync</div>
                <div class="font-display text-sm font-medium text-gold-soft">12 users</div>
              </div>
            </div>
          </div>

          <div class="absolute left-[-2%] top-[20%] h-3 w-3 rounded-full border border-gold bg-white"></div>
          <div class="absolute right-[10%] bottom-[-2%] h-2 w-2 rounded-full bg-gold"></div>
        </div>
      </div>
    </div>
  </div>
</section>
