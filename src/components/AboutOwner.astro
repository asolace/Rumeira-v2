---
const journey = [
  {
    year: '2017',
    role: 'Flatiron School',
    place: 'Bootcamp',
    body: 'Completed a 4-month immersive software engineering bootcamp — the foundation that turned a curiosity for the web into a career.',
  },
  {
    year: '2017',
    role: 'Junior Website Developer',
    place: 'DJA · Digital Marketing Agency',
    body: 'First role out of bootcamp. Shipped client websites and learned how marketing, design, and code actually work together to drive results.',
  },
  {
    year: '2019',
    role: 'Software Developer',
    place: 'Healthplex',
    body: 'Built software inside a regulated healthcare environment. Went deep on web compliance — HIPAA, ADA accessibility, and WCAG standards — so every product worked for every user.',
  },
  {
    year: 'Today',
    role: 'Principal Frontend Engineer',
    place: 'Morgan Stanley',
    body: 'Leads frontend engineering at scale for one of the largest financial institutions in the world. Where the engineering discipline behind Rumeira gets sharpened daily.',
  },
  {
    year: '2023',
    role: 'Founder',
    place: 'Rumeira',
    body: 'Launched Rumeira to bring enterprise-grade engineering, design, and AI strategy to the businesses that usually only get template work. Built to actually move the needle.',
  },
];

const socials = [
  { href: 'https://www.linkedin.com/in/asolace/', label: 'LinkedIn', icon: '/images/linkedin-logo.svg' },
  { href: 'https://www.facebook.com/Asolace', label: 'Facebook', icon: '/images/facebook-logo.svg' },
  { href: 'https://www.youtube.com/@mr-jack-he', label: 'YouTube', icon: '/images/youtube-logo.svg' },
];
---

<section id="owner" class="relative bg-black py-24 text-white md:py-36">
  <div class="pointer-events-none absolute inset-0 bg-grid-dark opacity-50 [mask-image:radial-gradient(ellipse_at_top,black_20%,transparent_70%)]"></div>
  <div class="pointer-events-none absolute -right-32 top-1/4 h-96 w-96 rounded-full bg-gold/10 blur-3xl"></div>

  <div class="container-x relative">
    <div class="grid items-start gap-16 lg:grid-cols-12 lg:gap-20">
      <!-- LEFT: portrait card -->
      <aside class="lg:col-span-5 lg:sticky lg:top-28">
        <div class="relative">
          <div class="absolute inset-0 -z-10 rounded-[2rem] bg-gradient-to-br from-gold/25 via-gold-soft/10 to-transparent blur-2xl"></div>

          <div class="overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-[#101010] to-[#050505] p-8 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)] md:p-10">
            <!-- Portrait -->
            <div class="relative aspect-square w-full overflow-hidden rounded-xl border border-white/10 bg-gradient-to-br from-gold/20 via-black to-black">
              <img
                src="/images/Jack He.webp"
                alt="Jack He, founder of Rumeira"
                width="600"
                height="600"
                class="absolute inset-0 h-full w-full object-cover"
                loading="lazy"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
              <div class="absolute bottom-4 right-4 h-2 w-2 rounded-full bg-gold-soft"></div>
            </div>

            <div class="mt-8">
              <div class="text-xs uppercase tracking-[0.2em] text-gold-soft">Founder · Engineer</div>
              <h3 class="mt-3 font-display text-3xl font-medium leading-tight md:text-4xl">Jack He</h3>
              <p class="mt-3 text-sm leading-relaxed text-white/60">
                Principal Frontend Engineer at Morgan Stanley. Founder of Rumeira. Building the systems that small businesses deserve.
              </p>
            </div>

            <div class="mt-8 flex items-center gap-3 border-t border-white/10 pt-6">
              {socials.map((s) => (
                <a
                  href={s.href}
                  aria-label={s.label}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex h-10 w-10 items-center justify-center rounded-full border border-white/0 transition-all duration-300 hover:border-gold hover:bg-white/5 hover:scale-110"
                >
                  <img src={s.icon} alt="" width="20" height="20" class="h-[20px] w-[20px] object-contain" loading="lazy" />
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>

      <!-- RIGHT: narrative + journey -->
      <div class="lg:col-span-7">
        <span class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.2em] text-gold-soft">
          <span class="h-px w-6 bg-gold-soft"></span>
          About the Owner
        </span>
        <h2 class="mt-5 font-display text-4xl font-medium leading-[1.05] tracking-tight md:text-5xl lg:text-6xl">
          From bootcamp,<br/>
          <span class="text-gold">to Wall Street, to Rumeira.</span>
        </h2>

        <div class="mt-8 space-y-6 text-base leading-relaxed text-white/70 md:text-lg">
          <p>
            Jack's journey began with a 4-month bootcamp at Flatiron School in 2017. That intensive program laid the groundwork for everything that came after — starting as a junior website developer at DJA, a digital marketing agency, where he learned how web and marketing actually compound when they're built together.
          </p>
          <p>
            His career then took him to Healthplex, where he expanded his expertise in software development and went deep on web compliance — HIPAA, ADA accessibility, and WCAG standards. That experience shaped a discipline he still carries: every site should work for every user, regardless of ability.
          </p>
          <p>
            Today, Jack is a Principal Frontend Engineer at Morgan Stanley, leading work on platforms used at enterprise scale. It's where the engineering rigor behind Rumeira gets sharpened every day.
          </p>
          <p>
            In 2023, driven by a passion for digital innovation and helping businesses thrive online, Jack launched Rumeira. The mission is simple: bring enterprise-grade marketing, design, and software to the businesses that need it most.
          </p>
        </div>

        <!-- Journey timeline -->
        <div class="mt-16">
          <div class="flex items-center gap-3 text-gold-soft">
            <span class="font-display text-sm">Journey</span>
            <span class="h-px flex-1 bg-white/10"></span>
          </div>

          <ol class="mt-8 space-y-px overflow-hidden rounded-2xl border border-white/10 bg-white/10">
            {journey.map((j, i) => (
              <li class="grid gap-4 bg-black p-6 transition-colors duration-500 hover:bg-white/[0.02] md:grid-cols-[7rem_1fr] md:gap-8 md:p-8">
                <div class="flex items-center gap-3 md:flex-col md:items-start md:gap-2">
                  <span class="font-display text-sm text-gold">{`0${i + 1}`}</span>
                  <span class="text-xs uppercase tracking-[0.18em] text-white/40">{j.year}</span>
                </div>
                <div>
                  <div class="font-display text-lg font-medium leading-tight md:text-xl">{j.role}</div>
                  <div class="mt-1 text-xs uppercase tracking-[0.15em] text-gold-soft">{j.place}</div>
                  <p class="mt-3 max-w-xl text-sm leading-relaxed text-white/60 md:text-base">{j.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>
