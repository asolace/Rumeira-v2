---
const pillars = [
  {
    n: '01',
    title: 'Workflow-first design',
    summary: 'We don\'t start with a feature list. We map how your team works today, the screens they bounce between, the shortcuts they use, the spreadsheet that secretly holds it together, and build software around that -not the other way around.',
    items: ['Workflow audit before kickoff', 'Real users in discovery', 'Mapped to your daily reality', 'Built around your team, not personas'],
  },
  {
    n: '02',
    title: 'Ship in weeks, not quarters',
    summary: 'Modern stacks let us turn small changes around in days, not release cycles. Your team requests a tweak on Monday and uses it the same week. No support portal, no roadmap queue, no waiting in line behind ten thousand other customers.',
    items: ['Continuous delivery from day one', 'Same-week iterations', 'No queued feature requests', 'Direct line to the engineers'],
  },
  {
    n: '03',
    title: 'A UI built for your team',
    summary: 'Off-the-shelf platforms force every customer through the same screens. We design the interface around your team\'s vocabulary, your processes, and the decisions they actually make every day -not the median customer the vendor designed for.',
    items: ['Custom flows, not generic screens', 'Your team\'s vocabulary', 'Role-specific views', 'Designed with the daily users'],
  },
  {
    n: '04',
    title: 'Built to grow with you',
    summary: 'Your software should not freeze at version one. We architect for change so the app evolves as your team scales, your processes mature, and your business shifts -without a rebuild every time something moves.',
    items: ['Architecture designed for change', 'Modular feature surface', 'Clean, scalable data model', 'Ongoing partnership, not handoff'],
  },
];
---

<section id="approach" class="bg-[#FBF8EF] py-24 md:py-36">
  <div class="container-x">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div class="max-w-2xl">
        <span class="eyebrow">
          <span class="h-px w-6 bg-gold"></span>
          The Approach
        </span>
        <h2 class="mt-5 font-display text-4xl font-medium leading-[1.05] tracking-tight md:text-6xl">
          Four pillars.<br/>
          <span class="text-gold">One operations engine.</span>
        </h2>
      </div>
      <p class="max-w-md text-base text-ink/60 md:text-lg">
        We don't sell software, we build the system your team runs on. Every app is custom, and every build follows the same four pillars.
      </p>
    </div>

    <div class="mt-16 grid gap-px overflow-hidden rounded-2xl border border-black/10 bg-black/10 md:grid-cols-2">
      {pillars.map((p) => (
        <article class="group relative flex flex-col bg-white p-8 transition-colors duration-500 hover:bg-gold/[0.03] md:p-10">
          <div class="flex items-center justify-between">
            <span class="font-display text-sm font-medium text-gold">{p.n}</span>
            <span class="h-1.5 w-1.5 rounded-full bg-ink/15 transition-colors group-hover:bg-gold"></span>
          </div>

          <h3 class="mt-10 font-display text-2xl font-medium leading-tight md:text-3xl">
            {p.title}
          </h3>
          <p class="mt-4 text-sm leading-relaxed text-ink/65 md:text-base">
            {p.summary}
          </p>

          <ul class="mt-8 space-y-3 border-t border-black/10 pt-6">
            {p.items.map((item) => (
              <li class="flex items-start gap-3 text-md text-ink/75">
                <svg class="mt-1 h-3 w-3 flex-none text-gold" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6.5L5 9.5L10 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
