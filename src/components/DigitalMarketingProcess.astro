---
const steps = [
  {
    n: '01',
    title: 'Audit',
    body: 'We map the funnel, the data, and the spend. What\'s working, what\'s leaking, and where the next dollar should go. Strategy before activity.',
  },
  {
    n: '02',
    title: 'Plan',
    body: 'A 90-day growth plan tied to a pipeline target. Channel mix, budget split, creative brief, measurement spine. Approved before anything launches.',
  },
  {
    n: '03',
    title: 'Launch',
    body: 'Tracking, accounts, and creative shipped in the first sprint. Built to measure on day one, not retrofitted three months in.',
  },
  {
    n: '04',
    title: 'Optimize',
    body: 'Weekly tuning across all channels. Kill what stalls, double what compounds, reallocate spend toward what proves out.',
  },
  {
    n: '05',
    title: 'Scale',
    body: 'Once unit economics hold, we push spend, expand channels, and compound. Monthly P&L on growth so you always know what you bought.',
  },
];
---

<section id="process" class="bg-white py-24 md:py-36">
  <div class="container-x">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">
        <span class="h-px w-6 bg-gold"></span>
        Process
      </span>
      <h2 class="mt-5 font-display text-4xl font-medium leading-[1.05] tracking-tight md:text-6xl">
        Five steps from audit to scale.
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-base text-ink/60 md:text-lg">
        Same sequence every engagement. Different output every engagement.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-5">
      {steps.map((s, i) => (
        <div class="relative flex flex-col rounded-2xl border border-gold/15 bg-[#FBF8EF]/40 p-6 transition-all duration-300 hover:border-gold/40 hover:bg-white">
          <div class="flex items-center justify-between">
            <span class="font-display text-2xl font-medium text-gold">{s.n}</span>
            {i < steps.length - 1 && (
              <svg class="hidden h-3 w-6 text-gold/40 md:block" viewBox="0 0 24 12" fill="none" aria-hidden="true">
                <path d="M1 6h22m0 0L18 1m5 5l-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <h3 class="mt-8 font-display text-xl font-medium">{s.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink/65">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
