---
---

<section class="relative overflow-hidden bg-white pt-32 pb-20 md:pt-40 md:pb-28">
  <div class="pointer-events-none absolute inset-0 bg-grid-light opacity-60 [mask-image:radial-gradient(ellipse_at_top_right,black_20%,transparent_70%)]"></div>
  <div class="pointer-events-none absolute -top-32 right-[-10%] h-[560px] w-[560px] rounded-full bg-gold/15 blur-3xl"></div>

  <div class="container-x relative">
    <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
      <!-- LEFT: copy -->
      <div class="lg:col-span-6 xl:col-span-7" style="max-width: 700px;">
        <span class="eyebrow">
          <span class="h-px w-6 bg-gold"></span>
          Digital Marketing
        </span>

        <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tightest text-ink sm:text-6xl md:text-7xl lg:text-[5rem] xl:text-[5.5rem]">
          One partner. Every
          <span>
            <span class="bg-gradient-to-r from-gold via-gold-light to-gold bg-clip-text text-transparent">channel</span><span class="text-ink">. Full</span>
          </span>
          <span class="text-ink">funnel growth.</span>
        </h1>

        <p class="mt-7 max-w-xl text-balance text-lg leading-relaxed text-ink/65 md:text-xl">
          Search, paid, content, and lifecycle - engineered as one growth system. We build the engine that turns <span class="font-medium text-ink">attention into pipeline</span>, every stage measured.
        </p>

        <div class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:gap-4">
          <a href="/get-started" class="btn-primary">
            Book a Strategy Call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#channels" class="btn-secondary">
            See Channels
          </a>
        </div>

        <div class="mt-12 grid grid-cols-3 gap-6 border-t border-black/10 pt-8">
          <div>
            <div class="font-display text-2xl font-medium text-ink md:text-3xl">4<span class="text-gold">x</span></div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Avg pipeline lift</div>
          </div>
          <div>
            <div class="font-display text-2xl font-medium text-ink md:text-3xl">90<span class="text-gold">d</span></div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">To first results</div>
          </div>
          <div>
            <div class="font-display text-2xl font-medium text-ink md:text-3xl">1</div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-ink/40">Integrated team</div>
          </div>
        </div>
      </div>

      <!-- RIGHT: funnel composition -->
      <div class="relative lg:col-span-6 xl:col-span-5">
        <div class="relative mx-auto aspect-[5/6] w-full" style="max-width: 580px;">
          <div class="absolute inset-0 -z-10 rounded-[2rem] bg-gradient-to-br from-gold/20 via-gold-soft/10 to-transparent blur-2xl"></div>

          <!-- Dashboard frame -->
          <div class="absolute inset-x-0 top-[6%] rounded-2xl border border-black/[0.06] bg-white shadow-[0_40px_100px_-30px_rgba(0,0,0,0.3)]">
            <div class="flex items-center gap-1.5 border-b border-black/[0.06] px-4 py-3">
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <div class="ml-3 flex h-5 flex-1 items-center justify-between rounded-md bg-ink/[0.04] px-2">
                <span class="text-[8px] uppercase tracking-[0.2em] text-ink/40">Pipeline overview</span>
                <span class="h-1.5 w-1.5 rounded-full bg-gold"></span>
              </div>
            </div>

            <div class="p-6">
              <!-- Top stats row -->
              <div class="grid grid-cols-3 gap-3">
                <div class="rounded-lg border border-black/[0.06] p-3">
                  <div class="text-[9px] uppercase tracking-wider text-ink/40">Sessions</div>
                  <div class="mt-1.5 font-display text-sm font-medium">42.8k</div>
                  <div class="mt-1 h-1 w-full rounded-full bg-gold/20">
                    <div class="h-full w-[78%] rounded-full bg-gold"></div>
                  </div>
                </div>
                <div class="rounded-lg border border-black/[0.06] p-3">
                  <div class="text-[9px] uppercase tracking-wider text-ink/40">Leads</div>
                  <div class="mt-1.5 font-display text-sm font-medium">1,204</div>
                  <div class="mt-1 h-1 w-full rounded-full bg-gold/20">
                    <div class="h-full w-[62%] rounded-full bg-gold"></div>
                  </div>
                </div>
                <div class="rounded-lg border border-black/[0.06] p-3">
                  <div class="text-[9px] uppercase tracking-wider text-ink/40">CAC</div>
                  <div class="mt-1.5 font-display text-sm font-medium">$48</div>
                  <div class="mt-1 h-1 w-full rounded-full bg-gold/20">
                    <div class="h-full w-[34%] rounded-full bg-gold"></div>
                  </div>
                </div>
              </div>

              <!-- Funnel block -->
              <div class="mt-6 space-y-2.5">
                <div class="flex items-center gap-3">
                  <span class="w-14 text-[9px] uppercase tracking-wider text-ink/40">Awareness</span>
                  <div class="h-5 flex-1 rounded-md bg-gradient-to-r from-gold/80 to-gold"></div>
                  <span class="font-display text-[10px] text-ink/60">100%</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="w-14 text-[9px] uppercase tracking-wider text-ink/40">Interest</span>
                  <div class="h-5 w-[78%] rounded-md bg-gradient-to-r from-gold/60 to-gold/90"></div>
                  <span class="font-display text-[10px] text-ink/60">78%</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="w-14 text-[9px] uppercase tracking-wider text-ink/40">Intent</span>
                  <div class="h-5 w-[42%] rounded-md bg-gradient-to-r from-gold/50 to-gold/80"></div>
                  <span class="font-display text-[10px] text-ink/60">42%</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="w-14 text-[9px] uppercase tracking-wider text-ink/40">Convert</span>
                  <div class="h-5 w-[18%] rounded-md bg-gradient-to-r from-gold/40 to-gold/70"></div>
                  <span class="font-display text-[10px] text-ink/60">18%</span>
                </div>
              </div>

              <!-- Channel tiles -->
              <div class="mt-6 grid grid-cols-4 gap-2">
                <div class="rounded-md border border-black/[0.06] p-2 text-center">
                  <div class="text-[8px] uppercase tracking-wider text-ink/40">SEO</div>
                  <div class="mt-1 font-display text-[10px] font-medium text-gold">+212%</div>
                </div>
                <div class="rounded-md border border-black/[0.06] p-2 text-center">
                  <div class="text-[8px] uppercase tracking-wider text-ink/40">Paid</div>
                  <div class="mt-1 font-display text-[10px] font-medium text-gold">3.4x</div>
                </div>
                <div class="rounded-md border border-black/[0.06] p-2 text-center">
                  <div class="text-[8px] uppercase tracking-wider text-ink/40">Email</div>
                  <div class="mt-1 font-display text-[10px] font-medium text-gold">38%</div>
                </div>
                <div class="rounded-md border border-black/[0.06] p-2 text-center">
                  <div class="text-[8px] uppercase tracking-wider text-ink/40">AI</div>
                  <div class="mt-1 font-display text-[10px] font-medium text-gold">+88%</div>
                </div>
              </div>
            </div>
          </div>

          <!-- ROAS badge (top right) -->
          <div class="absolute -right-2 top-0 rotate-[4deg] rounded-2xl border border-black/[0.06] bg-white p-4 shadow-[0_20px_50px_-20px_rgba(0,0,0,0.25)]">
            <div class="flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-full bg-gold/10">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M3 17l6-6 4 4 8-8M14 7h7v7" stroke="#987622" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-ink/40">ROAS</div>
                <div class="font-display text-sm font-medium">4.8x</div>
              </div>
            </div>
          </div>

          <!-- Pipeline pill (bottom left) -->
          <div class="absolute -left-3 bottom-[4%] rotate-[-3deg] rounded-2xl border border-white/40 bg-black p-4 text-white shadow-[0_20px_50px_-20px_rgba(0,0,0,0.45)]">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2">
                <span class="absolute inline-flex h-2 w-2 animate-ping rounded-full bg-gold-soft opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-gold-soft"></span>
              </span>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-white/50">Qualified pipeline</div>
                <div class="font-display text-sm font-medium text-gold-soft">+412%</div>
              </div>
            </div>
          </div>

          <div class="absolute left-[-2%] top-[20%] h-3 w-3 rounded-full border border-gold bg-white"></div>
          <div class="absolute right-[10%] bottom-[-2%] h-2 w-2 rounded-full bg-gold"></div>
        </div>
      </div>
    </div>
  </div>
</section>
