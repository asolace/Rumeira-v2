---
---

<section class="relative overflow-hidden bg-white pt-32 pb-20 md:pt-40 md:pb-28">
  <!-- Soft grid -->
  <div class="pointer-events-none absolute inset-0 bg-grid-light opacity-60 [mask-image:radial-gradient(ellipse_at_top_right,black_20%,transparent_70%)]"></div>

  <!-- Gold orb, shifted right -->
  <div class="pointer-events-none absolute -top-32 right-[-10%] h-[560px] w-[560px] rounded-full bg-gold/15 blur-3xl"></div>

  <div class="container-x relative">
    <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
      <!-- LEFT: copy -->
      <div class="lg:col-span-6 xl:col-span-7" style="max-width: 666px;">
        <span class="eyebrow">
          <span class="h-px w-6 bg-gold"></span>
          Digital Marketing · Website · AI Strategy
        </span>

        <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tightest text-ink sm:text-6xl md:text-7xl lg:text-[5rem] xl:text-[5.5rem]">
          Digital Marketing for
          <span class="block">
            <span class="bg-gradient-to-r from-gold via-gold-light to-gold bg-clip-text text-transparent">AI</span><span class="text-ink"> and </span><span class="bg-gradient-to-r from-gold via-gold-light to-gold bg-clip-text text-transparent">humans</span><span class="text-ink">.</span>
          </span>
        </h1>

        <p class="mt-7 max-w-xl text-balance text-lg leading-relaxed text-ink/65 md:text-xl">
          We help build and grow businesses with custom software, <span class="font-medium text-ink">conversion-driven</span> website design, search marketing, and <span class="ai-text">AI-powered solutions</span>.
        </p>

        <div class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:gap-4">
          <a href="#cta" class="btn-primary">
            Get a Free Strategy Call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#story" class="btn-secondary">
            See How It Works
          </a>
        </div>
      </div>

      <!-- RIGHT: composed visual -->
      <div class="relative lg:col-span-6 xl:col-span-5">
        <div class="relative mx-auto aspect-[5/6] w-full" style="max-width: 666px;">
          <!-- Backdrop glow -->
          <div class="absolute inset-0 -z-10 rounded-[2rem] bg-gradient-to-br from-gold/20 via-gold-soft/10 to-transparent blur-2xl"></div>

          <!-- Main "browser" card -->
          <div class="absolute left-0 top-0 w-[78%] origin-top-left rotate-[-1.5deg] rounded-2xl border border-black/[0.06] bg-white shadow-[0_30px_80px_-30px_rgba(0,0,0,0.25)]">
            <div class="flex items-center gap-1.5 border-b border-black/[0.06] px-4 py-3">
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <span class="h-2 w-2 rounded-full bg-ink/15"></span>
              <div class="ml-3 h-5 flex-1 rounded-md bg-ink/[0.04]"></div>
            </div>
            <div class="p-5">
              <div class="flex items-center justify-between">
                <span class="text-[10px] font-medium uppercase tracking-[0.18em] text-ink/40">Growth Overview</span>
                <span class="rounded-full bg-gold/10 px-2 py-0.5 text-[10px] font-medium text-gold">+218%</span>
              </div>

              <!-- Tiny chart -->
              <svg viewBox="0 0 200 80" class="mt-5 h-20 w-full" preserveAspectRatio="none" aria-hidden="true">
                <defs>
                  <linearGradient id="hf" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#987622" stop-opacity="0.35"/>
                    <stop offset="100%" stop-color="#987622" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d="M0,65 L20,60 L40,55 L60,48 L80,42 L100,30 L120,28 L140,18 L160,15 L180,8 L200,4 L200,80 L0,80 Z" fill="url(#hf)"/>
                <path d="M0,65 L20,60 L40,55 L60,48 L80,42 L100,30 L120,28 L140,18 L160,15 L180,8 L200,4" fill="none" stroke="#987622" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>

              <div class="mt-5 grid grid-cols-3 gap-3 border-t border-black/[0.06] pt-4">
                <div>
                  <div class="text-[10px] uppercase tracking-wider text-ink/40">Leads</div>
                  <div class="mt-1 font-display text-base font-medium">1,284</div>
                </div>
                <div>
                  <div class="text-[10px] uppercase tracking-wider text-ink/40">Calls</div>
                  <div class="mt-1 font-display text-base font-medium">432</div>
                </div>
                <div>
                  <div class="text-[10px] uppercase tracking-wider text-ink/40">CVR</div>
                  <div class="mt-1 font-display text-base font-medium text-gold">8.7%</div>
                </div>
              </div>
            </div>
          </div>

          <!-- AI workflow card (top right) -->
          <div class="absolute right-0 top-[6%] w-[52%] rotate-[3deg] rounded-2xl border border-white/40 bg-black p-5 text-white shadow-[0_30px_60px_-25px_rgba(0,0,0,0.55)]">
            <div class="flex items-center justify-between">
              <span class="text-[10px] font-medium uppercase tracking-[0.18em] text-gold-soft">AI Workflow</span>
              <span class="flex h-1.5 w-1.5">
                <span class="absolute inline-flex h-1.5 w-1.5 animate-ping rounded-full bg-gold-soft opacity-75"></span>
                <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-gold-soft"></span>
              </span>
            </div>

            <!-- Node graph -->
            <svg viewBox="0 0 160 110" class="mt-4 w-full" aria-hidden="true">
              <line x1="20" y1="22" x2="80" y2="55" stroke="#BC922C" stroke-width="1" stroke-dasharray="2 3"/>
              <line x1="20" y1="55" x2="80" y2="55" stroke="#BC922C" stroke-width="1" stroke-dasharray="2 3"/>
              <line x1="20" y1="88" x2="80" y2="55" stroke="#BC922C" stroke-width="1" stroke-dasharray="2 3"/>
              <line x1="80" y1="55" x2="140" y2="35" stroke="#BC922C" stroke-width="1" stroke-dasharray="2 3"/>
              <line x1="80" y1="55" x2="140" y2="75" stroke="#BC922C" stroke-width="1" stroke-dasharray="2 3"/>

              <g>
                <rect x="6" y="14" width="28" height="16" rx="3" fill="#1a1a1a" stroke="#3a3a3a"/>
                <rect x="6" y="47" width="28" height="16" rx="3" fill="#1a1a1a" stroke="#3a3a3a"/>
                <rect x="6" y="80" width="28" height="16" rx="3" fill="#1a1a1a" stroke="#3a3a3a"/>
                <circle cx="80" cy="55" r="9" fill="#987622"/>
                <rect x="126" y="27" width="28" height="16" rx="3" fill="#1a1a1a" stroke="#3a3a3a"/>
                <rect x="126" y="67" width="28" height="16" rx="3" fill="#1a1a1a" stroke="#3a3a3a"/>
              </g>
            </svg>

            <div class="mt-4 flex items-center justify-between border-t border-white/10 pt-3 text-[10px]">
              <span class="text-white/60">12 steps</span>
              <span class="text-gold-soft">Active</span>
            </div>
          </div>

          <!-- Metric pill (bottom right) -->
          <div class="absolute bottom-[6%] right-[4%] w-[58%] rotate-[-2deg] rounded-2xl border border-black/[0.06] bg-white p-5 shadow-[0_30px_60px_-25px_rgba(0,0,0,0.2)]">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gold/10 text-gold">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 2L3 7v6c0 5 4 9 9 9s9-4 9-9V7l-9-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-ink/40">Top 3 ranking</div>
                <div class="font-display text-sm font-medium">Local Map Pack</div>
              </div>
            </div>
            <div class="mt-4 grid grid-cols-3 gap-1.5">
              <div class="h-1 rounded-full bg-gold"></div>
              <div class="h-1 rounded-full bg-gold"></div>
              <div class="h-1 rounded-full bg-gold"></div>
              <div class="h-1 rounded-full bg-ink/10"></div>
              <div class="h-1 rounded-full bg-ink/10"></div>
              <div class="h-1 rounded-full bg-ink/10"></div>
            </div>
          </div>

          <!-- Floating dot accents -->
          <div class="absolute left-[-2%] bottom-[18%] h-3 w-3 rounded-full border border-gold bg-white"></div>
          <div class="absolute right-[10%] top-[-2%] h-2 w-2 rounded-full bg-gold"></div>
        </div>
      </div>
    </div>

    <!-- Trust strip (full width below) -->
    <div class="mt-20 grid grid-cols-2 gap-6 border-t border-black/10 pt-8 sm:grid-cols-4">
      {[
        { k: 'Search', v: 'Google, ChatGPT, Perplexity' },
        { k: 'Build', v: 'Website, Social Content' },
        { k: 'Automate', v: 'AI Workflows & CRMs' },
        { k: 'Scale', v: 'Ads + Organic + Local' },
      ].map((item) => (
        <div>
          <div class="text-xs uppercase tracking-[0.2em] text-ink/40">{item.k}</div>
          <div class="mt-2 text-sm font-medium text-ink">{item.v}</div>
        </div>
      ))}
    </div>
  </div>
</section>
