---
const metrics = [
  { value: '3.4x', label: 'Average lead-to-call rate after CRO + automation rollout' },
  { value: '< 1.2s', label: 'Median Core Web Vitals LCP on shipped websites' },
  { value: 'Top 3', label: 'Local Map Pack rankings for targeted service queries' },
  { value: '60%', label: 'Reduction in manual ops hours after AI workflow integration' },
];

const proofs = [
  {
    title: 'Local services brand',
    body: 'Rebuilt the site, locked in a top-3 map pack ranking, layered paid + organic. Booked calls increased 218% in 90 days.',
    tag: 'Web + SEO + Ads',
  },
  {
    title: 'B2B SaaS startup',
    body: 'Replaced a manual sales handoff with an AI workflow. Response time went from 14 hours to 2 minutes, conversion lifted 41%.',
    tag: 'AI Workflows',
  },
  {
    title: 'Multi-location retailer',
    body: 'Search Everywhere Optimization across Google, Perplexity, and ChatGPT. Tripled qualified inbound across new channels in one quarter.',
    tag: 'GEO + Content',
  },
];
---

<section id="results" class="bg-white py-24 md:py-36">
  <div class="container-x">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div class="max-w-2xl">
        <span class="eyebrow">
          <span class="h-px w-6 bg-gold"></span>
          Results
        </span>
        <h2 class="mt-5 font-display text-4xl font-medium leading-[1.05] tracking-tight md:text-6xl">
          Outcomes you can<br/>
          <span class="text-ink/40">put on the P&amp;L.</span>
        </h2>
      </div>
      <p class="max-w-md text-base text-ink/60 md:text-lg">
        We measure the things that move revenue. Here is what that looks like in practice.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-black/10 bg-black/10 lg:grid-cols-4">
      {metrics.map((m) => (
        <div class="flex flex-col gap-4 bg-white p-8 md:p-10">
          <div class="font-display text-4xl font-medium tracking-tight text-ink md:text-5xl">
            {m.value}
          </div>
          <div class="text-sm leading-relaxed text-ink/55">{m.label}</div>
        </div>
      ))}
    </div>

    <div class="mt-20 grid gap-6 md:grid-cols-3">
      {proofs.map((p) => (
        <article class="group rounded-2xl border border-black/10 bg-white p-8 transition-all duration-500 hover:border-gold/40 hover:shadow-[0_24px_60px_-30px_rgba(152,118,34,0.35)]">
          <span class="inline-flex items-center gap-2 rounded-full border border-gold/30 bg-gold/[0.04] px-3 py-1 text-xs font-medium text-gold">
            {p.tag}
          </span>
          <h3 class="mt-6 font-display text-xl font-medium leading-tight md:text-2xl">
            {p.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-ink/65">{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
