---
---

<section id="cta" class="cta-section">
  <div class="container">
    <div class="bezel cta-card is-in" data-reveal>
      <div class="bezel__core cta-core">
        <div class="cta-glow" aria-hidden="true"></div>

        <span class="eyebrow">Start with Rumeira</span>
        <h2 class="h2 cta-title">Let's build your growth engine.</h2>
        <p class="lead cta-text">
          Tell us where you want to go. We will map the marketing, the <span class="ai-text-dark">AI</span>, and the measurement to get you there.
        </p>

        <div class="btn-row cta-actions">
          <a href="/get-started" class="btn btn--primary">
            Book a strategy call
            <span class="btn__icon" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none">
                <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: #000000;
    padding-top: 5rem;
  }
  @media (min-width: 768px) {
    .cta-section { padding-top: 6rem; }
  }

  .cta-section .container {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (min-width: 1024px) {
    .cta-section .container { padding: 0 2.5rem; }
  }

  /* Bezel -outer frame (double border) */
  .bezel.cta-card {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    border-radius: 1.75rem;
    padding: 1px;
    /* Outer ring */
    background: linear-gradient(135deg,
      rgba(224, 198, 123, 0.22) 0%,
      rgba(152, 118, 34, 0.08) 50%,
      rgba(255, 255, 255, 0.02) 100%);
    box-shadow:
      0 24px 70px -40px rgba(152, 118, 34, 0.35),
      inset 0 0 0 1px rgba(255, 255, 255, 0.015);
  }
  @media (min-width: 768px) {
    .bezel.cta-card { border-radius: 2rem; }
  }

  /* Mid frame -creates the gap between outer and inner border */
  .bezel.cta-card > .bezel__core {
    position: relative;
    /* Inner ring */
    box-shadow:
      inset 0 0 0 1px rgba(224, 198, 123, 0.12),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.04);
  }

  /* Core -mostly black with subtle gold warmth */
  .bezel__core.cta-core {
    overflow: hidden;
    border-radius: 1.65rem;
    padding: 2.75rem 1.75rem;
    background:
      radial-gradient(ellipse 70% 80% at 50% 0%, rgba(152, 118, 34, 0.28) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 50% 100%, rgba(152, 118, 34, 0.08) 0%, transparent 70%),
      linear-gradient(180deg, #0e0e0e 0%, #050505 100%);
    color: #ffffff;
    text-align: center;
    isolation: isolate;
  }
  @media (min-width: 768px) {
    .bezel__core.cta-core {
      border-radius: 1.9rem;
      padding: 3.75rem 2.75rem;
    }
  }

  /* Soft glow inside the core (very subtle) */
  .cta-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }
  .cta-glow::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 65%;
    height: 90%;
    border-radius: 9999px;
    background: rgba(224, 198, 123, 0.14);
    filter: blur(80px);
  }

  /* Faint dot texture */
  .bezel__core.cta-core::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.06;
    background-image: radial-gradient(rgba(255, 255, 255, 0.5) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  /* Typography */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.85);
  }
  .eyebrow::before {
    content: '';
    width: 1.25rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.8);
  }

  .h2.cta-title {
    margin: 1rem 0 0;
    font-family: 'Clash Display', system-ui, sans-serif;
    font-size: clamp(1.625rem, 2.4vw + 1rem, 2.75rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #ffffff;
  }

  .lead.cta-text {
    margin: 1rem auto 0;
    max-width: 32rem;
    font-size: clamp(0.875rem, 0.6vw + 0.75rem, 1rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Button row */
  .btn-row.cta-actions {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
  }
  @media (min-width: 640px) {
    .btn-row.cta-actions { flex-direction: row; }
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 9999px;
    padding: 0.75rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .btn:active { transform: scale(0.98); }

  .btn--primary {
    background: linear-gradient(135deg, #BC922C 0%, #987622 100%);
    color: #ffffff;
    box-shadow:
      0 10px 30px -10px rgba(152, 118, 34, 0.55),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.18);
  }
  .btn--primary:hover {
    background: linear-gradient(135deg, #E0C67B 0%, #BC922C 100%);
    box-shadow:
      0 14px 40px -10px rgba(152, 118, 34, 0.7),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.25);
  }

  .btn__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.18);
    transition: background 0.3s ease;
  }
  .btn--primary:hover .btn__icon {
    background: rgba(255, 255, 255, 0.28);
  }
  .btn__icon svg {
    width: 0.625rem;
    height: 0.625rem;
  }

  /* Reveal hook (no JS needed -keeps class for future animation) */
  .cta-card.is-in { opacity: 1; transform: none; }
</style>
