<section id="cta" class="relative overflow-hidden bg-gold text-white">
  <div class="pointer-events-none absolute inset-0 opacity-30 [background-image:radial-gradient(rgba(255,255,255,0.25)_1px,transparent_1px)] [background-size:32px_32px]"></div>
  <div class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-gold-soft/40 blur-3xl"></div>
  <div class="pointer-events-none absolute -left-32 -bottom-32 h-96 w-96 rounded-full bg-black/20 blur-3xl"></div>

  <div class="container-x relative py-24 md:py-32">
    <div class="mx-auto max-w-4xl text-center">
      <span class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.2em] text-white/80">
        <span class="h-px w-6 bg-white/80"></span>
        Let's build it
      </span>
      <h2 class="mt-5 font-display text-4xl font-medium leading-[1.05] tracking-tight text-white md:text-6xl lg:text-7xl">
        Ready to build a smarter growth system?
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-white/80">
        Tell us where you are today. We'll show you exactly where the next 6 months of growth come from.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
        <a href="mailto:start@rumeira.com?subject=Book%20a%20call" class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-7 py-3.5 text-sm font-medium text-ink transition-all duration-300 hover:bg-gold-soft hover:text-ink active:scale-[0.98]">
          Book a Call
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12m0 0L8 2m5 5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="mailto:start@rumeira.com?subject=Free%20Audit" class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 bg-transparent px-7 py-3.5 text-sm font-medium text-white transition-all duration-300 hover:bg-white/10 active:scale-[0.98]">
          Get a Free Audit
        </a>
      </div>

      <p class="mt-8 text-xs uppercase tracking-[0.2em] text-white/60">
        Reply within 24 hours. No pressure, no junk.
      </p>
    </div>
  </div>
</section>
